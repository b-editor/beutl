    <SolidColorBrush x:Key="AccentAcrylicBackgroundFillColorBaseBrush" Color="{DynamicResource SystemAccentColorDark2}" />
    <SolidColorBrush x:Key="AccentAcrylicInAppFillColorBaseBrush" Color="{DynamicResource SystemControlAccentColorDark2}" />
    <SolidColorBrush x:Key="AppBarToggleButtonCheckedDisabledBorderThemeBrush" Color="Transparent" />
    <SolidColorBrush x:Key="AppBarToggleButtonCheckedPressedBackgroundThemeBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ColorViewContentBackgroundBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ColorViewContentBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ColorViewTabBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="BreadcrumbBarBackgroundBrush" Color="Transparent" />
    <SolidColorBrush x:Key="BreadcrumbBarBorderBrush" Color="Transparent" />

    <!-- ===== Acrylic / Direct-color SolidColorBrushes ===== -->
    <SolidColorBrush x:Key="AcrylicBackgroundFillColorDefaultBrush" Color="#222222" />
    <SolidColorBrush x:Key="AcrylicInAppFillColorDefaultBrush" Color="#222222" />
    <SolidColorBrush x:Key="AcrylicBackgroundFillColorDefaultInverseBrush" Color="#F9F9F9" />
    <SolidColorBrush x:Key="AcrylicInAppFillColorDefaultInverseBrush" Color="#F9F9F9" />
    <SolidColorBrush x:Key="AcrylicBackgroundFillColorBaseBrush" Color="#161616" />
    <SolidColorBrush x:Key="AcrylicInAppFillColorBaseBrush" Color="#161616" />
