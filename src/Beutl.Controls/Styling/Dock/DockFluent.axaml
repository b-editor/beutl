<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=netstandard">
    <!--
        Overrides for wieslawsoltes/Dock's Fluent theme. The original Fluent
        theme uses StaticResource aliases, so we must override each concrete
        *Brush key directly — overriding only the upstream alias would not
        take effect once the original theme dictionary has been parsed.
    -->

    <ResourceDictionary.ThemeDictionaries>
        <!--  Dark: explicit darker surfaces to match Beutl's MacMainViewBackground (#111).  -->
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="DockThemeBackgroundBrush" Color="#1A1A1A" />
            <SolidColorBrush x:Key="DockThemeControlBackgroundBrush" Color="#202020" />
            <SolidColorBrush x:Key="DockThemeBorderLowBrush" Color="#33000000" />

            <SolidColorBrush x:Key="DockSurfaceWorkbenchBrush" Color="#0F0F0F" />
            <SolidColorBrush x:Key="DockSurfaceSidebarBrush" Color="#181818" />
            <SolidColorBrush x:Key="DockSurfaceEditorBrush" Color="#1C1C1C" />
            <SolidColorBrush x:Key="DockSurfacePanelBrush" Color="#1A1A1A" />
            <SolidColorBrush x:Key="DockSurfaceHeaderBrush" Color="#202020" />
            <SolidColorBrush x:Key="DockSurfaceHeaderActiveBrush" Color="#262626" />

            <SolidColorBrush x:Key="DockBorderSubtleBrush" Color="#2A2A2A" />
            <SolidColorBrush x:Key="DockBorderStrongBrush" Color="#3A3A3A" />
            <SolidColorBrush x:Key="DockSeparatorBrush" Color="#2A2A2A" />
            <SolidColorBrush x:Key="DockSplitterIdleBrush" Color="#2A2A2A" />

            <SolidColorBrush x:Key="DockTabBackgroundBrush" Color="Transparent" />
            <SolidColorBrush x:Key="DockTabHoverBackgroundBrush" Color="#262626" />
            <SolidColorBrush x:Key="DockTabActiveBackgroundBrush" Color="#2D2D2D" />

            <SolidColorBrush x:Key="DockDocumentTabStripBackgroundBrush" Color="Transparent" />

            <SolidColorBrush x:Key="DockChromeButtonHoverBackgroundBrush" Color="#262626" />
            <SolidColorBrush x:Key="DockChromeButtonPressedBackgroundBrush" Color="#2D2D2D" />
        </ResourceDictionary>

        <!--  Light: keep the Fluent defaults (DynamicResource hooks).  -->
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="DockThemeBackgroundBrush" Color="{DynamicResource LayerFillColorDefault}" />
            <SolidColorBrush x:Key="DockThemeControlBackgroundBrush" Color="{DynamicResource ControlFillColorDefault}" />
            <SolidColorBrush x:Key="DockThemeBorderLowBrush" Color="{DynamicResource ControlStrokeColorDefault}" />

            <SolidColorBrush x:Key="DockSurfaceWorkbenchBrush" Color="{DynamicResource SolidBackgroundFillColorBase}" />
            <SolidColorBrush x:Key="DockSurfaceSidebarBrush" Color="{DynamicResource LayerFillColorDefault}" />
            <SolidColorBrush x:Key="DockSurfaceEditorBrush" Color="{DynamicResource ControlFillColorDefault}" />
            <SolidColorBrush x:Key="DockSurfacePanelBrush" Color="{DynamicResource LayerFillColorDefault}" />
            <SolidColorBrush x:Key="DockSurfaceHeaderBrush" Color="{DynamicResource SubtleFillColorSecondary}" />
            <SolidColorBrush x:Key="DockSurfaceHeaderActiveBrush" Color="{DynamicResource SubtleFillColorTertiary}" />

            <SolidColorBrush x:Key="DockBorderSubtleBrush" Color="{DynamicResource ControlStrokeColorDefault}" />
            <SolidColorBrush x:Key="DockBorderStrongBrush" Color="{DynamicResource ControlStrongStrokeColorDefault}" />
            <SolidColorBrush x:Key="DockSeparatorBrush" Color="{DynamicResource ControlStrokeColorDefault}" />
            <SolidColorBrush x:Key="DockSplitterIdleBrush" Color="{DynamicResource ControlStrokeColorDefault}" />

            <SolidColorBrush x:Key="DockTabBackgroundBrush" Color="Transparent" />
            <SolidColorBrush x:Key="DockTabHoverBackgroundBrush" Color="{DynamicResource SubtleFillColorSecondary}" />
            <SolidColorBrush x:Key="DockTabActiveBackgroundBrush" Color="{DynamicResource ControlFillColorDefault}" />

            <SolidColorBrush x:Key="DockDocumentTabStripBackgroundBrush" Color="Transparent" />

            <SolidColorBrush x:Key="DockChromeButtonHoverBackgroundBrush" Color="{DynamicResource SubtleFillColorSecondary}" />
            <SolidColorBrush x:Key="DockChromeButtonPressedBackgroundBrush" Color="{DynamicResource SubtleFillColorTertiary}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!--  ===== Accent brushes (tied to FluentAvalonia's SystemAccentColor) =====  -->
    <SolidColorBrush x:Key="DockApplicationAccentBrushLow" Color="{DynamicResource SystemAccentColorDark1}" />
    <SolidColorBrush x:Key="DockApplicationAccentBrushMed" Color="{DynamicResource SystemAccentColor}" />
    <SolidColorBrush x:Key="DockApplicationAccentBrushHigh" Color="{DynamicResource SystemAccentColorLight1}" />
    <SolidColorBrush x:Key="DockApplicationAccentForegroundBrush" Color="{DynamicResource TextOnAccentFillColorPrimary}" />
    <SolidColorBrush x:Key="DockApplicationAccentBrushIndicator" Color="{DynamicResource SystemAccentColor}" />
    <SolidColorBrush x:Key="DockThemeAccentBrush" Color="{DynamicResource SystemAccentColor}" />
    <SolidColorBrush x:Key="DockThemeForegroundBrush" Color="{DynamicResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="DockTargetIndicatorBrush" Color="{DynamicResource SystemAccentColor}" />

    <!--  Tab foregrounds: must be visible on all states  -->
    <SolidColorBrush x:Key="DockTabForegroundBrush" Color="{DynamicResource TextFillColorSecondary}" />
    <SolidColorBrush x:Key="DockTabSelectedForegroundBrush" Color="{DynamicResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="DockTabActiveForegroundBrush" Color="{DynamicResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="DockTabActiveIndicatorBrush" Color="{DynamicResource SystemAccentColor}" />
    <SolidColorBrush x:Key="DockTabCloseHoverBackgroundBrush" Color="{DynamicResource SubtleFillColorTertiary}" />

    <SolidColorBrush x:Key="DockDocumentTabSelectedForegroundBrush" Color="{DynamicResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="DockDocumentTabPointerOverForegroundBrush" Color="{DynamicResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="DockDocumentTabCloseSelectedForegroundBrush" Color="{DynamicResource TextFillColorSecondary}" />
    <SolidColorBrush x:Key="DockDocumentTabClosePointerOverForegroundBrush" Color="{DynamicResource TextFillColorPrimary}" />

    <SolidColorBrush x:Key="DockSplitterHoverBrush" Color="{DynamicResource SystemAccentColorLight1}" />
    <SolidColorBrush x:Key="DockSplitterDragBrush" Color="{DynamicResource SystemAccentColor}" />

    <SolidColorBrush x:Key="DockChromeButtonDangerHoverBrush" Color="{DynamicResource SystemFillColorCriticalBackground}" />

    <!--  ===== Typography =====  -->
    <sys:Double x:Key="DockFontSizeNormal">12</sys:Double>

    <!--  ===== Geometry / density =====  -->
    <sys:Double x:Key="DockCornerRadiusSmall">4</sys:Double>
    <sys:Double x:Key="DockHeaderHeight">28</sys:Double>
    <sys:Double x:Key="DockTabHeight">28</sys:Double>
    <sys:Double x:Key="DockTabItemMinHeight">26</sys:Double>
    <sys:Double x:Key="DockDocumentTabItemMinHeight">26</sys:Double>
    <sys:Double x:Key="DockDocumentTabItemMinWidth">80</sys:Double>
    <sys:Double x:Key="DockToolTabItemMinHeight">26</sys:Double>
    <sys:Double x:Key="DockDocumentTabStripMinHeight">30</sys:Double>
    <sys:Double x:Key="DockDocumentTabItemSeparatorOpacity">1</sys:Double>
    <Thickness x:Key="DockDocumentTabItemMargin">0,0,2,0</Thickness>
    <Thickness x:Key="DockDocumentTabItemPadding">10,4,10,4</Thickness>
    <Thickness x:Key="DockToolTabItemPadding">8,2,8,2</Thickness>
    <Thickness x:Key="DockToolTabItemSelectedPadding">8,2,8,2</Thickness>
    <CornerRadius x:Key="DockDocumentTabItemCornerRadius">4,4,0,0</CornerRadius>
    <CornerRadius x:Key="DockDocumentTabCreateButtonCornerRadius">4</CornerRadius>

    <sys:Double x:Key="DockIconSizeSmall">12</sys:Double>
    <sys:Double x:Key="DockIconSizeNormal">14</sys:Double>
</ResourceDictionary>
