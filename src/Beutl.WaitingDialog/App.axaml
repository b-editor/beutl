<Application x:Class="Beutl.WaitingDialog.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="NotoSansJP">avares://Beutl.WaitingDialog/Assets/Fonts#Noto Sans JP</FontFamily>
            <FontFamily x:Key="BeutlUIFontFamily">avares://Beutl.WaitingDialog/Assets/Fonts#Noto Sans JP</FontFamily>
            <StaticResource x:Key="ContentControlThemeFontFamily" ResourceKey="BeutlUIFontFamily" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <sty:FluentAvaloniaTheme />
    </Application.Styles>
</Application>
