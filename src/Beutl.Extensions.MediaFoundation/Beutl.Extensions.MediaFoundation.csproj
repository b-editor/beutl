<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RepositoryUrl>https://github.com/b-editor/beutl</RepositoryUrl>
    <Authors>b-editor</Authors>

    <MFBuildIn Condition="'$(MFBuildIn)' == ''">True</MFBuildIn>
    <DefineConstants>$(DefineConstants);DESKTOP_APP</DefineConstants>
    <DefineConstants Condition="'$(MFBuildIn)'=='True'">$(DefineConstants);MF_BUILD_IN</DefineConstants>
    <!-- This extension relies on Direct3D9 / DXVA2 (IDirect3DDeviceManager9), which the
         Win32 metadata marks x86/x64-only, so it cannot be built for win-arm64. Callers
         exclude it from arm64 builds; here we keep the historical x64 target. -->
    <PlatformTarget Condition="'$(PlatformTarget)' == '' And ($([MSBuild]::IsOSPlatform('Windows')) Or $(RuntimeIdentifier.StartsWith('win')))">x64</PlatformTarget>
    <UseResXGenerator>true</UseResXGenerator>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWin32">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="NAudio.Wasapi" />
    <PackageReference Include="Vortice.MediaFoundation" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Beutl.Extensibility\Beutl.Extensibility.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Grant the test project access to internal decoding helpers (TimestampUtilities,
         MFMediaInfo, the CsWin32-generated MFRatio/RECT, etc.). -->
    <InternalsVisibleTo Include="Beutl.Extensions.MediaFoundation.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Properties\Strings.resx" />
  </ItemGroup>

  <Choose>
    <When Condition="'$(MFBuildIn)'=='True'">
      <PropertyGroup>
        <AssemblyName>Beutl.Embedding.MediaFoundation</AssemblyName>
        <PackageId>Beutl.Embedding.MediaFoundation</PackageId>
        <Title>Beutl.Embedding.MediaFoundation</Title>
      </PropertyGroup>
    </When>
    <Otherwise>
      <PropertyGroup>
        <AssemblyName>Beutl.Extensions.MediaFoundation</AssemblyName>
        <PackageId>Beutl.Extensions.MediaFoundation</PackageId>
        <Title>Beutl.Extensions.MediaFoundation</Title>
        <SideloadOutput>true</SideloadOutput>
      </PropertyGroup>
    </Otherwise>
  </Choose>

  <!-- Sideload output layout; see build/props/SideloadOutput.props. -->
  <Import Project="$(RootDirectory)build\props\SideloadOutput.props" />

</Project>
