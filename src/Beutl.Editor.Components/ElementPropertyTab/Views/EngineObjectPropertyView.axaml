<UserControl x:Class="Beutl.Editor.Components.ElementPropertyTab.Views.EngineObjectPropertyView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:icons="using:FluentIcons.FluentAvalonia"
             xmlns:lang="using:Beutl.Language"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="using:Beutl.Editor.Components.ElementPropertyTab.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:CompileBindings="True"
             x:DataType="viewModel:EngineObjectPropertyViewModel"
             DragDrop.AllowDrop="True"
             mc:Ignorable="d">
    <Expander MinHeight="44"
              Padding="0"
              IsExpanded="{Binding IsExpanded.Value, Mode=TwoWay, FallbackValue=True}">
        <Expander.Resources>
            <SolidColorBrush x:Key="ExpanderContentBackground" Color="Transparent" />
            <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="Transparent" />
            <Thickness x:Key="ExpanderHeaderPadding">8,0,0,0</Thickness>
            <Thickness x:Key="ExpanderContentDownBorderThickness">0,0,0,0</Thickness>
            <x:Double x:Key="ExpanderChevronButtonSize">24</x:Double>
            <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="{DynamicResource DividerStrokeColorDefault}" />
            <SolidColorBrush x:Key="ExpanderHeaderBorderPointerOverBrush" Color="{DynamicResource DividerStrokeColorDefault}" />
            <SolidColorBrush x:Key="ExpanderBorderPressedBrush" Color="{DynamicResource DividerStrokeColorDefault}" />
            <SolidColorBrush x:Key="ExpanderHeaderDisabledBorderBrush" Color="{DynamicResource DividerStrokeColorDefault}" />
        </Expander.Resources>
        <Expander.Styles>
            <Style Selector="Expander /template/ ToggleButton#ExpanderHeader">
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
            </Style>
        </Expander.Styles>
        <Expander.Header>
            <StackPanel x:Name="headerPanel"
                        Background="Transparent"
                        Orientation="Horizontal">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Click="Remove_Click" Header="{x:Static lang:Strings.Remove}">
                            <MenuItem.Icon>
                                <icons:SymbolIcon Symbol="Delete" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <Border x:Name="dragBorder"
                        CornerRadius="{DynamicResource ControlCornerRadius}"
                        Cursor="SizeNorthSouth">
                    <Border.Styles>
                        <Style Selector="Border:pointerover">
                            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                        </Style>
                    </Border.Styles>
                    <icons:SymbolIcon VerticalAlignment="Center"
                                      FontSize="16"
                                      Symbol="ReOrderDotsVertical" />
                </Border>

                <ToggleButton IsChecked="{Binding IsEnabled.Value}" Theme="{StaticResource VisibilityToggleButtonStyle}" />

                <TextBlock x:Name="headerText" VerticalAlignment="Center" />
            </StackPanel>
        </Expander.Header>

        <Panel x:Name="panel">
            <!--  ここに何か追加する場合、OnDataContextChangedでIndex、Countをハードコードしているので、考慮する  -->
            <ItemsControl Grid.IsSharedSizeScope="True" ItemsSource="{Binding Properties}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding Converter={StaticResource ViewModelToViewConverter}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Panel>
    </Expander>
</UserControl>
