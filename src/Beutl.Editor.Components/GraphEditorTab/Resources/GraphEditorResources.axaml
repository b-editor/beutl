<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:view="using:Beutl.Editor.Components.GraphEditorTab.Views"
                    xmlns:icons="using:FluentIcons.FluentAvalonia"
                    xmlns:lang="using:Beutl.Language"
                    xmlns:viewModel="using:Beutl.Editor.Components.GraphEditorTab.ViewModels">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <!-- GraphEditor Light Mode Colors -->
            <SolidColorBrush x:Key="GraphEditorBackgroundBrush">#F5F5F5</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorGridLineBrush">#19000000</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorScaleTextBrush">#B4404040</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorControlPointFillBrush">#E0EAF5</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorControlPointStrokeBrush">#4080D0</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorHandleLineBrush">#80606060</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorKeyFrameBrush">#FF8C3D</SolidColorBrush>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <!-- GraphEditor Dark Mode Colors -->
            <SolidColorBrush x:Key="GraphEditorBackgroundBrush">#1E1E1E</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorGridLineBrush">#28FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorScaleTextBrush">#B4C8C8C8</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorControlPointFillBrush">#203050</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorControlPointStrokeBrush">#60A0FF</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorHandleLineBrush">#80D0D0D0</SolidColorBrush>
            <SolidColorBrush x:Key="GraphEditorKeyFrameBrush">#FFB84D</SolidColorBrush>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <PathGeometry x:Key="GraphEditorControlPointGeometry">
        <PathGeometry.Figures>
            <PathFigure IsClosed="True" StartPoint="0.0,-4.5">
                <ArcSegment Point=" 4.5, 0.0" Size="4.5, 4.5" />
                <ArcSegment Point=" 0.0, 4.5" Size="4.5, 4.5" />
                <ArcSegment Point="-4.5, 0.0" Size="4.5, 4.5" />
                <ArcSegment Point=" 0.0,-4.5" Size="4.5, 4.5" />
            </PathFigure>
        </PathGeometry.Figures>
    </PathGeometry>


    <PathGeometry x:Key="GraphEditorKeyTimeGeometry">
        <PathGeometry.Figures>
            <PathFigure StartPoint="0,-6">
                <LineSegment Point="6,0" />
                <LineSegment Point="0,6" />
                <LineSegment Point="-6,0" />
            </PathFigure>
        </PathGeometry.Figures>
    </PathGeometry>


    <DataTemplate x:Key="GraphEditorEaseLineTemplate" x:DataType="viewModel:GraphEditorKeyFrameViewModel">
        <view:EaseLine Baseline="{Binding Baseline.Value}"
                       Easing="{Binding Model.Easing}"
                       EndX="{Binding Right.Value}"
                       EndY="{Binding EndY.Value}"
                       StartX="{Binding Left.Value}"
                       StartY="{Binding StartY.Value}"
                       Stroke="{Binding Stroke.Value}"
                       StrokeThickness="2" />
    </DataTemplate>


    <DataTemplate x:Key="GraphEditorKeyFramePointsTemplate" x:DataType="viewModel:GraphEditorKeyFrameViewModel">
        <Border Width="{Binding Width.Value}"
                Margin="{Binding Margin.Value}"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch">

            <Border Height="{Binding Height.Value}"
                    Margin="{Binding BoundsMargin.Value}"
                    VerticalAlignment="Top">
                <Panel>
                    <Line IsHitTestVisible="False"
                          IsVisible="{Binding IsSplineEasing.Value}"
                          Stroke="{DynamicResource GraphEditorHandleLineBrush}"
                          StrokeThickness="1.5"
                          StartPoint="{Binding ControlPoint1.Value}"
                          EndPoint="{Binding LeftBottom.Value}" />

                    <Line IsHitTestVisible="False"
                          IsVisible="{Binding IsSplineEasing.Value}"
                          Stroke="{DynamicResource GraphEditorHandleLineBrush}"
                          StrokeThickness="1.5"
                          StartPoint="{Binding ControlPoint2.Value}"
                          EndPoint="{Binding RightTop.Value}" />

                    <Path Name="KeyTimeIcon"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Data="{StaticResource GraphEditorKeyTimeGeometry}"
                          Classes.decreasing="{Binding Decreasing.Value}"
                          Fill="{DynamicResource GraphEditorKeyFrameBrush}"
                          view:KeyTimeBehavior.Attached="True">
                        <Path.RenderTransform>
                            <TranslateTransform X="{Binding RightTop.Value.X}" Y="{Binding RightTop.Value.Y}" />
                        </Path.RenderTransform>
                        <Path.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="{Binding CopyCommand}" Header="{x:Static lang:Strings.Copy}">
                                    <MenuItem.Icon>
                                        <icons:SymbolIcon Symbol="Copy" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Command="{Binding PasteCommand}" Header="{x:Static lang:Strings.Paste}">
                                    <MenuItem.Icon>
                                        <icons:SymbolIcon Symbol="ClipboardPaste" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Command="{Binding RemoveCommand}" Header="{x:Static lang:Strings.Delete}">
                                    <MenuItem.Icon>
                                        <icons:SymbolIcon Symbol="Delete" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Path.ContextMenu>
                    </Path>

                    <Path HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Data="{StaticResource GraphEditorControlPointGeometry}"
                          Fill="{DynamicResource GraphEditorControlPointFillBrush}"
                          IsVisible="{Binding IsSplineEasing.Value}"
                          view:ControlPointBehavior.Attached="True"
                          Stroke="{DynamicResource GraphEditorControlPointStrokeBrush}"
                          StrokeThickness="2"
                          Tag="ControlPoint1">
                        <Path.RenderTransform>
                            <TranslateTransform X="{Binding ControlPoint1.Value.X}" Y="{Binding ControlPoint1.Value.Y}" />
                        </Path.RenderTransform>
                    </Path>

                    <Path HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Data="{StaticResource GraphEditorControlPointGeometry}"
                          Fill="{DynamicResource GraphEditorControlPointFillBrush}"
                          IsVisible="{Binding IsSplineEasing.Value}"
                          view:ControlPointBehavior.Attached="True"
                          Stroke="{DynamicResource GraphEditorControlPointStrokeBrush}"
                          StrokeThickness="2"
                          Tag="ControlPoint2">
                        <Path.RenderTransform>
                            <TranslateTransform X="{Binding ControlPoint2.Value.X}" Y="{Binding ControlPoint2.Value.Y}" />
                        </Path.RenderTransform>
                    </Path>
                </Panel>
            </Border>
        </Border>
    </DataTemplate>
</ResourceDictionary>
