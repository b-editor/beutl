<UserControl x:Class="Beutl.Editor.Components.EqualizerProperties.Views.EqualizerPropertiesEditor"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Beutl.Editor.Components.EqualizerProperties.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Beutl.Editor.Components.EqualizerProperties.ViewModels"
             x:Name="root"
             d:DesignHeight="400"
             d:DesignWidth="400"
             x:CompileBindings="True"
             x:DataType="vm:EqualizerPropertiesViewModel"
             mc:Ignorable="d">
    <StackPanel x:Name="contentPanel"
                Margin="0,8,0,4"
                Spacing="6">
        <local:EqualizerCurveEditor x:Name="curveEditor"
                                    Height="180"
                                    Margin="0,0,0,4"
                                    BandViewModels="{Binding Bands}"
                                    CurrentTime="{Binding CurrentTime.Value}"
                                    SampleRate="{Binding SampleRate.Value}"
                                    SelectedBandIndex="{Binding SelectedBandIndex.Value}" />

        <Border Padding="4,4,0,4"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding SelectedBand.Value, Converter={x:Static ObjectConverters.IsNotNull}}">
            <StackPanel DataContext="{Binding SelectedBand.Value}" Spacing="2">
                <!--  Debug中だけだが、個別にDataContextを設定しないと、なぜかInvalidCastExceptionが発生する。  -->
                <TextBlock Text="{Binding Label.Value, StringFormat='Band: {0} Hz'}" />
                <ContentControl Content="{Binding Converter={StaticResource ViewModelToViewConverter}}" DataContext="{Binding FrequencyEditor}" />
                <ContentControl Content="{Binding Converter={StaticResource ViewModelToViewConverter}}"
                                DataContext="{Binding GainEditor}"
                                IsVisible="{Binding $parent.((vm:EqualizerBandItemViewModel)DataContext).IsGainVisible.Value, FallbackValue=False}" />
                <ContentControl Content="{Binding Converter={StaticResource ViewModelToViewConverter}}" DataContext="{Binding QEditor}" />
                <ContentControl Content="{Binding Converter={StaticResource ViewModelToViewConverter}}" DataContext="{Binding FilterTypeEditor}" />
            </StackPanel>
        </Border>

        <ContentControl Content="{Binding Converter={StaticResource ViewModelToViewConverter}}" DataContext="{Binding BandCountEditor.Value}" />
    </StackPanel>
</UserControl>
