<UserControl x:Class="Beutl.Editor.Components.AudioVisualizerTab.Views.AudioVisualizerTabView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:icons="using:FluentIcons.FluentAvalonia"
             xmlns:lang="using:Beutl.Language"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Beutl.Editor.Components.AudioVisualizerTab.ViewModels"
             xmlns:views="using:Beutl.Editor.Components.AudioVisualizerTab.Views"
             d:DesignHeight="220"
             d:DesignWidth="480"
             x:CompileBindings="True"
             x:DataType="viewModels:AudioVisualizerTabViewModel"
             mc:Ignorable="d">
    <Grid RowDefinitions="Auto,*">
        <Grid Height="32" ColumnDefinitions="Auto,*,Auto">
            <ComboBox Grid.Column="0"
                      Margin="8,0,0,0"
                      VerticalAlignment="Center"
                      SelectedIndex="{Binding SelectedMode.Value, Converter={x:Static views:AudioVisualizerModeConverter.Instance}, Mode=TwoWay}"
                      Theme="{StaticResource LiteComboBoxStyle}">
                <ComboBoxItem Content="{x:Static lang:Strings.Waveform}"
                              ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_Waveform_Description}" />
                <ComboBoxItem Content="{x:Static lang:Strings.Spectrum}"
                              ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_Spectrum_Description}" />
                <ComboBoxItem Content="{x:Static lang:Strings.Meter}"
                              ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_Meter_Description}" />
                <ComboBoxItem Content="{x:Static lang:Strings.Spectrogram}"
                              ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_Spectrogram_Description}" />
                <ComboBoxItem Content="{x:Static lang:Strings.PhaseScope}"
                              ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_PhaseScope_Description}" />
            </ComboBox>

            <Button Grid.Column="2"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    Theme="{StaticResource TransparentButton}"
                    ToolTip.Tip="{x:Static lang:Strings.Settings}">
                <icons:SymbolIcon Symbol="Settings" />
                <Button.Flyout>
                    <Flyout Placement="Bottom">
                        <Flyout.FlyoutPresenterTheme>
                            <ControlTheme BasedOn="{StaticResource {x:Type FlyoutPresenter}}"
                                          TargetType="FlyoutPresenter">
                                <Setter Property="Padding" Value="0" />
                            </ControlTheme>
                        </Flyout.FlyoutPresenterTheme>

                        <StackPanel Width="288">
                            <StackPanel.Styles>
                                <Style Selector="TextBlock.section">
                                    <Setter Property="Theme" Value="{StaticResource BodyStrongTextBlockStyle}" />
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <Setter Property="Margin" Value="0,0,0,4" />
                                </Style>
                                <Style Selector="TextBlock.field">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Style>
                                <Style Selector="Border.value-badge">
                                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                    <Setter Property="CornerRadius" Value="4" />
                                    <Setter Property="Padding" Value="6,1,6,1" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="MinWidth" Value="48" />
                                </Style>
                                <Style Selector="Border.value-badge > TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Style>
                            </StackPanel.Styles>

                            <!-- Header -->
                            <Border Padding="16,12,16,12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <icons:SymbolIcon Symbol="Settings" FontSize="16" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static lang:Strings.Settings}"
                                               Theme="{StaticResource BodyStrongTextBlockStyle}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Separator Height="1" Margin="0" />

                            <!-- Spectrum section -->
                            <StackPanel Margin="16,12,16,8" Spacing="10">
                                <TextBlock Classes="section" Text="Spectrum" />

                                <Grid ColumnDefinitions="92,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="12"
                                      RowSpacing="8">
                                    <TextBlock Classes="field" Text="FFT Size" />
                                    <ComboBox Grid.Column="1"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding AvailableFftSizes}"
                                              SelectedItem="{Binding FftSize.Value, Mode=TwoWay}"
                                              Tag="FftSize"
                                              PointerPressed="OnSettingPointerPressed"
                                              ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_ResetTooltip}" />

                                    <TextBlock Grid.Row="1" Classes="field" Text="Shape" />
                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding AvailableSpectrumShapes}"
                                              SelectedItem="{Binding SpectrumShape.Value, Mode=TwoWay}"
                                              Tag="SpectrumShape"
                                              PointerPressed="OnSettingPointerPressed"
                                              ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_ResetTooltip}" />
                                </Grid>

                                <StackPanel Spacing="4"
                                            Tag="Smoothing"
                                            PointerPressed="OnSettingPointerPressed"
                                            ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_ResetTooltip}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="field" Text="Smoothing" />
                                        <Border Grid.Column="1" Classes="value-badge">
                                            <TextBlock Text="{Binding Smoothing.Value, StringFormat={}{0:0}%}" />
                                        </Border>
                                    </Grid>
                                    <Slider Maximum="95"
                                            Minimum="0"
                                            TickFrequency="5"
                                            Value="{Binding Smoothing.Value, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>

                            <Separator Height="1" Margin="0,0,0,4" />

                            <!-- Display section -->
                            <StackPanel Margin="16,8,16,12" Spacing="10">
                                <TextBlock Classes="section" Text="Display" />

                                <StackPanel Spacing="4"
                                            Tag="MinDecibels"
                                            PointerPressed="OnSettingPointerPressed"
                                            ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_ResetTooltip}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Classes="field" Text="Min dB" />
                                        <Border Grid.Column="1" Classes="value-badge">
                                            <TextBlock Text="{Binding MinDecibels.Value, StringFormat={}{0:0} dB}" />
                                        </Border>
                                    </Grid>
                                    <Slider Maximum="-40"
                                            Minimum="-120"
                                            TickFrequency="10"
                                            Value="{Binding MinDecibels.Value, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <Panel Grid.Row="1" Margin="4">
            <views:WaveformControl ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_Waveform_Description}"
                                   IsVisible="{Binding SelectedMode.Value, Converter={x:Static views:AudioVisualizerModeConverter.Instance}, ConverterParameter=Waveform}"
                                   PlayheadTime="{Binding PlayheadTime.Value}"
                                   RingBuffer="{Binding RingBuffer}" />

            <views:SpectrumControl ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_Spectrum_Description}"
                                   FftSize="{Binding FftSize.Value}"
                                   IsVisible="{Binding SelectedMode.Value, Converter={x:Static views:AudioVisualizerModeConverter.Instance}, ConverterParameter=Spectrum}"
                                   MinDecibels="{Binding MinDecibels.Value}"
                                   PlayheadTime="{Binding PlayheadTime.Value}"
                                   RingBuffer="{Binding RingBuffer}"
                                   Shape="{Binding SpectrumShape.Value}"
                                   Smoothing="{Binding Smoothing.Value}" />

            <views:LevelMeterControl ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_Meter_Description}"
                                     IsVisible="{Binding SelectedMode.Value, Converter={x:Static views:AudioVisualizerModeConverter.Instance}, ConverterParameter=Meter}"
                                     PlayheadTime="{Binding PlayheadTime.Value}"
                                     RingBuffer="{Binding RingBuffer}" />

            <views:SpectrogramControl ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_Spectrogram_Description}"
                                      FftSize="{Binding FftSize.Value}"
                                      IsVisible="{Binding SelectedMode.Value, Converter={x:Static views:AudioVisualizerModeConverter.Instance}, ConverterParameter=Spectrogram}"
                                      MinDecibels="{Binding MinDecibels.Value}"
                                      PlayheadTime="{Binding PlayheadTime.Value}"
                                      RingBuffer="{Binding RingBuffer}" />

            <views:PhaseScopeControl ToolTip.Tip="{x:Static lang:Strings.AudioVisualizer_PhaseScope_Description}"
                                     IsVisible="{Binding SelectedMode.Value, Converter={x:Static views:AudioVisualizerModeConverter.Instance}, ConverterParameter=PhaseScope}"
                                     PlayheadTime="{Binding PlayheadTime.Value}"
                                     RingBuffer="{Binding RingBuffer}" />
        </Panel>
    </Grid>
</UserControl>
