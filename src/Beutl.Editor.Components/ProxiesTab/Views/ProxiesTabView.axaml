<UserControl x:Class="Beutl.Editor.Components.ProxiesTab.Views.ProxiesTabView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Beutl.Editor.Components.ProxiesTab.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="320"
             x:CompileBindings="True"
             x:DataType="vm:ProxiesTabViewModel"
             mc:Ignorable="d">
    <Grid Margin="8" RowDefinitions="Auto,Auto,*,Auto,Auto">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <ComboBox Width="112"
                      ItemsSource="{Binding PresetOptions}"
                      SelectedItem="{Binding SelectedPreset.Value, Mode=TwoWay}" />
            <Button Command="{Binding GenerateAllCommand}" Content="Generate all" />
            <Button Command="{Binding RefreshCommand}" Content="Refresh" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,8,0,6" Spacing="4">
            <TextBlock Text="{Binding StoreSummary.Value}" />
            <Button HorizontalAlignment="Left"
                    Command="{Binding DeleteAllForProjectCommand}"
                    Content="Delete project proxies" />
        </StackPanel>

        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Clips}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProxyClipViewModel">
                        <Grid Margin="0,0,0,8" ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.ColumnSpan="3"
                                       FontWeight="SemiBold"
                                       Text="{Binding FileName}" />
                            <TextBlock Grid.Row="1"
                                       Opacity="0.7"
                                       Text="{Binding Path}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="8,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding State}" />
                            <StackPanel Grid.Row="1"
                                        Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="4">
                                <Button Command="{Binding GenerateCommand}" Content="Generate" />
                                <Button Command="{Binding DeleteCommand}" Content="Delete" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <ItemsControl Grid.Row="3" Margin="0,8,0,0" ItemsSource="{Binding PendingJobs}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ProxyJobViewModel">
                    <Grid ColumnDefinitions="*,64,Auto,Auto,Auto,Auto">
                        <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                        <ProgressBar Grid.Column="1"
                                     Height="6"
                                     Margin="8,0,0,0"
                                     Maximum="1"
                                     Value="{Binding ProgressValue}" />
                        <TextBlock Grid.Column="2"
                                   Margin="8,0"
                                   Text="{Binding ProgressText}" />
                        <TextBlock Grid.Column="3"
                                   Margin="8,0"
                                   Text="{Binding Preset}" />
                        <TextBlock Grid.Column="4"
                                   Margin="8,0"
                                   Text="{Binding Status}" />
                        <Button Grid.Column="5"
                                Margin="8,0,0,0"
                                Command="{Binding CancelCommand}"
                                Content="Cancel" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Grid.Row="4"
                   Margin="0,8,0,0"
                   Opacity="0.75"
                   Text="{Binding StatusMessage.Value}"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
