<UserControl x:Class="Beutl.Pages.SettingsPages.AiAgentSettingsPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="using:Beutl.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Beutl.Language"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:Beutl.ViewModels.SettingsPages"
             x:Name="root"
             d:DesignHeight="700"
             d:DesignWidth="800"
             x:CompileBindings="True"
             x:DataType="vm:AiAgentSettingsPageViewModel"
             mc:Ignorable="d">
    <Grid Margin="18" RowDefinitions="Auto,*">

        <TextBlock Margin="10,8"
                   Text="{x:Static lang:SettingsStrings.AiAgents}"
                   Theme="{StaticResource SimpleLargeBreadcrumbBarTextBlock}" />

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="10,16,10,0"
                        VerticalAlignment="Stretch"
                        Orientation="Vertical"
                        Spacing="4">
                <SelectableTextBlock Text="{x:Static lang:SettingsStrings.AiAgents_PageDescription}" TextWrapping="Wrap" />

                <TextBlock Margin="0,16,0,0"
                           Text="{x:Static lang:SettingsStrings.AiAgents_Target}"
                           Theme="{StaticResource BodyStrongTextBlockStyle}" />

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_Agent_Description}" Header="{x:Static lang:SettingsStrings.AiAgents_Agent}">
                    <ctrls:OptionsDisplayItem.ActionButton>
                        <ComboBox MinWidth="250"
                                  ItemsSource="{Binding AgentChoices}"
                                  SelectedItem="{Binding SelectedAgent.Value}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:AgentChoiceItem">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </ctrls:OptionsDisplayItem.ActionButton>
                </ctrls:OptionsDisplayItem>

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_Scope_Description}"
                                          Header="{x:Static lang:SettingsStrings.AiAgents_Scope}"
                                          IsEnabled="{Binding IsScopeSelectable.Value}">
                    <ctrls:OptionsDisplayItem.ActionButton>
                        <ComboBox MinWidth="250"
                                  ItemsSource="{Binding ScopeChoices}"
                                  SelectedItem="{Binding SelectedScope.Value}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:InstallScopeItem">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </ctrls:OptionsDisplayItem.ActionButton>
                </ctrls:OptionsDisplayItem>

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_ProjectFolder_Description}"
                                          Header="{x:Static lang:SettingsStrings.AiAgents_ProjectFolder}"
                                          IsVisible="{Binding IsProjectFolderVisible.Value}">
                    <ctrls:OptionsDisplayItem.ActionButton>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox MinWidth="280" Text="{Binding ProjectRoot.Value}" />
                            <Button Click="BrowseProjectRoot_Click" Content="..." />
                        </StackPanel>
                    </ctrls:OptionsDisplayItem.ActionButton>
                </ctrls:OptionsDisplayItem>

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_WorkspaceRoot_Description}" Header="{x:Static lang:SettingsStrings.AiAgents_WorkspaceRoot}">
                    <ctrls:OptionsDisplayItem.ActionButton>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox MinWidth="280" Text="{Binding WorkspaceRoot.Value}" />
                            <Button Click="BrowseWorkspaceRoot_Click" Content="..." />
                        </StackPanel>
                    </ctrls:OptionsDisplayItem.ActionButton>
                </ctrls:OptionsDisplayItem>

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_Destinations_Description}"
                                          Expands="True"
                                          Header="{x:Static lang:SettingsStrings.AiAgents_Destinations}">
                    <ctrls:OptionsDisplayItem.Content>
                        <Grid Margin="40,0,40,8"
                              ColumnDefinitions="180,*"
                              ColumnSpacing="8"
                              RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="4">
                            <TextBlock Text="{x:Static lang:SettingsStrings.AiAgents_Skills}" />
                            <SelectableTextBlock Grid.Column="1"
                                                 FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                                 FontSize="12"
                                                 Text="{Binding ResolvedSkillsPath.Value}"
                                                 TextWrapping="Wrap" />

                            <TextBlock Grid.Row="1" Text="{x:Static lang:SettingsStrings.AiAgents_Subagents}" />
                            <SelectableTextBlock Grid.Row="1"
                                                 Grid.Column="1"
                                                 FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                                 FontSize="12"
                                                 Text="{Binding ResolvedSubagentsPath.Value}"
                                                 TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Text="{x:Static lang:SettingsStrings.AiAgents_McpConfigFileName}" />
                            <SelectableTextBlock Grid.Row="2"
                                                 Grid.Column="1"
                                                 FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                                 FontSize="12"
                                                 Text="{Binding ResolvedMcpConfigPath.Value}"
                                                 TextWrapping="Wrap" />
                        </Grid>
                    </ctrls:OptionsDisplayItem.Content>
                </ctrls:OptionsDisplayItem>

                <TextBlock Margin="0,16,0,0"
                           Text="{x:Static lang:SettingsStrings.AiAgents_Components}"
                           Theme="{StaticResource BodyStrongTextBlockStyle}" />

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_Skills_Description}" Header="{x:Static lang:SettingsStrings.AiAgents_Skills}">
                    <ctrls:OptionsDisplayItem.ActionButton>
                        <ToggleSwitch Classes="left"
                                      IsChecked="{Binding InstallSkills.Value}"
                                      Theme="{StaticResource CompactToggleSwitchStyle}" />
                    </ctrls:OptionsDisplayItem.ActionButton>
                </ctrls:OptionsDisplayItem>

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_Subagents_Description}"
                                          Header="{x:Static lang:SettingsStrings.AiAgents_Subagents}"
                                          IsEnabled="{Binding CanInstallSubagents.Value}">
                    <ctrls:OptionsDisplayItem.ActionButton>
                        <ToggleSwitch Classes="left"
                                      IsChecked="{Binding InstallSubagents.Value}"
                                      Theme="{StaticResource CompactToggleSwitchStyle}" />
                    </ctrls:OptionsDisplayItem.ActionButton>
                </ctrls:OptionsDisplayItem>

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_StdioMcp_Description}"
                                          Header="{x:Static lang:SettingsStrings.AiAgents_StdioMcp}"
                                          IsEnabled="{Binding CanInstallMcp.Value}">
                    <ctrls:OptionsDisplayItem.ActionButton>
                        <ToggleSwitch Classes="left"
                                      IsChecked="{Binding InstallStdioMcp.Value}"
                                      Theme="{StaticResource CompactToggleSwitchStyle}" />
                    </ctrls:OptionsDisplayItem.ActionButton>
                </ctrls:OptionsDisplayItem>

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_LiveMcp_Description}"
                                          Header="{x:Static lang:SettingsStrings.AiAgents_LiveMcp}"
                                          IsEnabled="{Binding CanInstallLiveMcp.Value}">
                    <ctrls:OptionsDisplayItem.ActionButton>
                        <ToggleSwitch Classes="left"
                                      IsChecked="{Binding InstallLiveMcp.Value}"
                                      Theme="{StaticResource CompactToggleSwitchStyle}" />
                    </ctrls:OptionsDisplayItem.ActionButton>
                </ctrls:OptionsDisplayItem>

                <ui:InfoBar IsClosable="False"
                            IsOpen="{Binding !CanInstallMcp.Value}"
                            Message="{x:Static lang:SettingsStrings.AiAgents_McpManual}"
                            Severity="Informational" />

                <ui:InfoBar IsClosable="False"
                            IsOpen="{Binding !IsLiveMcpAvailable.Value}"
                            Message="{x:Static lang:SettingsStrings.AiAgents_LiveMcp_NotRunning}"
                            Severity="Warning" />

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_LiveMcpUrl_Description}"
                                          Expands="True"
                                          Header="{x:Static lang:SettingsStrings.AiAgents_LiveMcpUrl}"
                                          IsVisible="{Binding IsLiveMcpAvailable.Value}">
                    <ctrls:OptionsDisplayItem.Content>
                        <DockPanel Margin="40,0,40,8">
                            <StackPanel Margin="8,0,0,0"
                                        DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Click="CopyLiveMcpUrl_Click" Content="{x:Static lang:Strings.Copy}" />
                                <Button Click="RefreshLiveMcp_Click" Content="{x:Static lang:Strings.Refresh}" />
                            </StackPanel>
                            <TextBox IsReadOnly="True" Text="{Binding LiveMcpUrl.Value}" />
                        </DockPanel>
                    </ctrls:OptionsDisplayItem.Content>
                </ctrls:OptionsDisplayItem>

                <ctrls:OptionsDisplayItem Description="{x:Static lang:SettingsStrings.AiAgents_Advanced_Description}"
                                          Expands="True"
                                          Header="{x:Static lang:SettingsStrings.AiAgents_Advanced}">
                    <ctrls:OptionsDisplayItem.Content>
                        <Grid Margin="40,0,40,8"
                              ColumnDefinitions="180,*"
                              ColumnSpacing="8"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="8">
                            <TextBlock VerticalAlignment="Center" Text="{x:Static lang:SettingsStrings.AiAgents_SkillsDirectory}" />
                            <TextBox Grid.Column="1"
                                     MaxWidth="360"
                                     HorizontalAlignment="Left"
                                     MinWidth="240"
                                     Text="{Binding SkillsDirectory.Value}" />

                            <TextBlock Grid.Row="1"
                                       VerticalAlignment="Center"
                                       Text="{x:Static lang:SettingsStrings.AiAgents_SubagentsDirectory}" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     MaxWidth="360"
                                     MinWidth="240"
                                     HorizontalAlignment="Left"
                                     Text="{Binding SubagentsDirectory.Value}" />

                            <TextBlock Grid.Row="2"
                                       VerticalAlignment="Center"
                                       Text="{x:Static lang:SettingsStrings.AiAgents_McpConfigFileName}" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     MaxWidth="360"
                                     MinWidth="240"
                                     HorizontalAlignment="Left"
                                     Text="{Binding McpConfigFileName.Value}" />

                            <TextBlock Grid.Row="3"
                                       VerticalAlignment="Center"
                                       Text="{x:Static lang:SettingsStrings.AiAgents_McpServersPropertyName}" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     MaxWidth="360"
                                     MinWidth="240"
                                     HorizontalAlignment="Left"
                                     Text="{Binding McpServersPropertyName.Value}" />

                            <TextBlock Grid.Row="4"
                                       VerticalAlignment="Center"
                                       Text="{x:Static lang:SettingsStrings.AiAgents_McpCommand}" />
                            <TextBox Grid.Row="4"
                                     Grid.Column="1"
                                     MinWidth="360"
                                     Text="{Binding McpCommand.Value}" />

                            <TextBlock Grid.Row="5"
                                       VerticalAlignment="Top"
                                       Text="{x:Static lang:SettingsStrings.AiAgents_McpArguments}" />
                            <TextBox Grid.Row="5"
                                     Grid.Column="1"
                                     MinHeight="96"
                                     MinWidth="360"
                                     AcceptsReturn="True"
                                     FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                     Text="{Binding McpArguments.Value}"
                                     TextWrapping="NoWrap" />
                        </Grid>
                    </ctrls:OptionsDisplayItem.Content>
                </ctrls:OptionsDisplayItem>

                <StackPanel Margin="0,16,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="8">
                    <ui:ProgressRing Width="24"
                                     Height="24"
                                     IsVisible="{Binding IsInstalling.Value}" />
                    <Button MinWidth="120"
                            Classes="accent"
                            Command="{Binding Install}"
                            Content="{x:Static lang:SettingsStrings.AiAgents_Install}" />
                </StackPanel>

                <SelectableTextBlock MinHeight="24"
                                     Text="{Binding Status.Value}"
                                     TextWrapping="Wrap" />

                <ctrls:OptionsDisplayItem Expands="True"
                                          Header="{x:Static lang:SettingsStrings.AiAgents_InstalledFiles}"
                                          IsVisible="{Binding HasInstalledFiles.Value}">
                    <ctrls:OptionsDisplayItem.Content>
                        <ItemsControl Margin="40,0,40,8" ItemsSource="{Binding InstalledFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <SelectableTextBlock FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                                         FontSize="12"
                                                         Text="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ctrls:OptionsDisplayItem.Content>
                </ctrls:OptionsDisplayItem>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
