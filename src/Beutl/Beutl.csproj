<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework></TargetFramework><!-- empty so the TFMs below cross-target -->
    <TargetFrameworks>net10.0;net10.0-windows</TargetFrameworks>
    <OutputType>WinExe</OutputType>
    <DesktopExeRids>true</DesktopExeRids>
    <FFmpegBuildIn Condition="'$(FFmpegBuildIn)' == ''">True</FFmpegBuildIn>
    <MFBuildIn Condition="'$(MFBuildIn)' == '' And $(TargetFramework.Contains('windows'))">True</MFBuildIn>
    <!-- AVFoundationはmacOS専用。osx-* RID向けpublish時、または非Windows TFMの開発ビルド
         (RID未指定) のときに含める。Linux/Windows向けpublishでは除外する。 -->
    <AVFBuildIn Condition="'$(AVFBuildIn)' == '' And !$(TargetFramework.Contains('windows')) And ('$(RuntimeIdentifier)' == '' Or $(RuntimeIdentifier.StartsWith('osx')))">True</AVFBuildIn>
    <DefineConstants Condition="'$(FFmpegBuildIn)'=='True'">$(DefineConstants);FFMPEG_BUILD_IN</DefineConstants>
    <DefineConstants Condition="'$(MFBuildIn)'=='True'">$(DefineConstants);MF_BUILD_IN</DefineConstants>
    <DefineConstants Condition="'$(AVFBuildIn)'=='True'">$(DefineConstants);AVF_BUILD_IN</DefineConstants>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>..\Beutl.Controls\Assets\logo.ico</ApplicationIcon>
  </PropertyGroup>

  <PropertyGroup Condition="$(TargetFramework.Contains('windows'))">
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <PropertyGroup>
    <CFBundleName>Beutl</CFBundleName>
    <CFBundleDisplayName>Beutl</CFBundleDisplayName>
    <CFBundleIdentifier>net.beditor.beutl</CFBundleIdentifier>
    <!-- スクリプトから指定 -->
    <!-- <CFBundleVersion>$(AssemblyVersion)</CFBundleVersion> -->
    <!-- <CFBundleShortVersionString>$(AssemblyVersion)</CFBundleShortVersionString> -->
    <CFBundlePackageType>APPL</CFBundlePackageType>
    <CFBundleSignature>????</CFBundleSignature>
    <CFBundleExecutable>Beutl</CFBundleExecutable>
    <CFBundleIconFile>$(RootDirectory)\assets\logos\Beutl.icns</CFBundleIconFile>
    <NSPrincipalClass>NSApplication</NSPrincipalClass>
    <NSHighResolutionCapable>true</NSHighResolutionCapable>
  </PropertyGroup>
  <!-- <PropertyGroup>
    <OutputPath>bin\$(Configuration)\$(Platform)\Beutl.app/Contents/MacOS</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <UseAppHost>true</UseAppHost>
  </PropertyGroup> -->

  <ItemGroup Condition="$(TargetFramework.Contains('windows'))">
    <Using Remove="System.Drawing" />
    <Using Remove="System.Windows.Forms" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="AsyncImageLoader.Avalonia" />
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Controls.ItemsRepeater" />
    <PackageReference Include="PanAndZoom" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Diagnostics" Condition="'$(Configuration)' == 'Debug'" />
    <PackageReference Include="ReactiveUI.Avalonia" />
    <PackageReference Include="Svg.Controls.Skia.Avalonia" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Xaml.Behaviors.Avalonia" />
    <PackageReference Include="Xaml.Behaviors.Interactivity" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
    <PackageReference Include="Dotnet.Bundle" />
    <PackageReference Include="DynamicData" />
    <PackageReference Include="FluentAvaloniaUI" />
    <PackageReference Include="FluentIcons.FluentAvalonia" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="ModelContextProtocol" />
    <PackageReference Include="ModelContextProtocol.AspNetCore" />
    <PackageReference Include="OpenTelemetry" />
    <PackageReference Include="PanelExtension" />
    <PackageReference Include="ReactiveProperty" />
    <PackageReference Include="Dock.Avalonia" />
    <PackageReference Include="Dock.Model.Inpc" />
    <PackageReference Include="Dock.Avalonia.Themes.Fluent" />
    <PackageReference Include="Serilog.Extensions.Logging" />
    <PackageReference Include="Serilog.Sinks.Async" />
    <PackageReference Include="Serilog.Sinks.File" />
    <PackageReference Include="Serilog.Sinks.Debug" />
    <PackageReference Include="System.Reactive" />
    <PackageReference Include="System.Interactive" />
    <PackageReference Include="Roslynator.Analyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Beutl.Api\Beutl.Api.csproj" />
    <ProjectReference Include="..\Beutl.AgentToolkit\Beutl.AgentToolkit.csproj" />
    <ProjectReference Include="..\Beutl.Controls\Beutl.Controls.csproj" />
    <ProjectReference Include="..\Beutl.Editor\Beutl.Editor.csproj" />
    <ProjectReference Include="..\Beutl.Editor.Components\Beutl.Editor.Components.csproj" />
    <ProjectReference Condition="'$(NukePublish)'!='True'"
      Include="..\Beutl.PackageTools.UI\Beutl.PackageTools.UI.csproj" />
    <ProjectReference Condition="'$(NukePublish)'!='True'"
      Include="..\Beutl.WaitingDialog\Beutl.WaitingDialog.csproj" />
    <ProjectReference Condition="'$(NukePublish)'!='True'"
      Include="..\Beutl.ExceptionHandler\Beutl.ExceptionHandler.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(FFmpegBuildIn)'=='True'">
    <ProjectReference Include="..\Beutl.Extensions.FFmpeg\Beutl.Extensions.FFmpeg.csproj" />
  </ItemGroup>

  <!-- Dev-only build of the GPL worker. ReferenceOutputAssembly=false keeps the GPL assembly
       out of the MIT compile closure (GPL/MIT boundary invariant); CopyFFmpegWorkerForApp below
       mirrors the worker's full output into an isolated FFmpegWorker/ subdirectory next to the
       app, where FFmpegWorkerProcess probes (it prefers that subdir, then falls back to
       AppContext.BaseDirectory). The worker resolves its own (possibly different-versioned)
       shared assemblies from its own deps.json inside that subdir, so its dependency closure
       never overwrites the app's. Nuke release publishes (Publish / BundleApp targets) instead lay
       the worker out flat, merging its whole closure into the app dir with FileSkip so the app's
       shared assemblies stay the single canonical set; only the worker's identity and its private
       GPL deps (FFmpeg.AutoGen, FFmpegSharp) — absent from the app's MIT set — are added. Copying
       only Beutl.FFmpegWorker* would strand those private deps and the worker would fail to start.
       NOTE: CopyFFmpegWorkerForApp runs AfterTargets="Build" and copies into $(OutDir) (bin), not
       $(PublishDir). A bare `dotnet publish` (NukePublish!=True) therefore omits the worker and
       yields a non-runnable app; publishing a runnable app must go through Nuke (NukePublish=True),
       which lays out the worker as above. -->
  <ItemGroup Condition="'$(NukePublish)'!='True'">
    <ProjectReference Include="..\Beutl.FFmpegWorker\Beutl.FFmpegWorker.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- The '$(TargetFramework)' != '' guard keeps this off the outer (dispatch) pass of the
       multi-targeting build, where TargetFramework and OutDir are empty: there the glob base
       would collapse to bin\$(Configuration)\ (pulling the TFM folders into %(RecursiveDir)) and
       the empty OutDir would land the copy in the project source directory. Only the inner
       per-TFM build has the correct OutDir under bin\. -->
  <Target Name="CopyFFmpegWorkerForApp"
          AfterTargets="Build"
          Condition="'$(NukePublish)'!='True' And '$(TargetFramework)' != ''">
    <PropertyGroup>
      <!-- The worker's own output dir mirrors this app's: it gains a <RID> segment only when a
           RuntimeIdentifier is set. Anchor the glob there so a RID build does not duplicate the
           RID into $(OutDir) (which already ends in <RID>) and strand the worker outside
           AppContext.BaseDirectory. -->
      <_FFmpegWorkerOutDir>..\Beutl.FFmpegWorker\bin\$(Configuration)\$(TargetFramework)\$(RuntimeIdentifier)\</_FFmpegWorkerOutDir>
    </PropertyGroup>
    <ItemGroup>
      <_FFmpegWorkerOutput Include="$(_FFmpegWorkerOutDir)**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(_FFmpegWorkerOutput)"
          DestinationFiles="@(_FFmpegWorkerOutput->'$(OutDir)FFmpegWorker\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup Condition="'$(MFBuildIn)'=='True'">
    <ProjectReference
      Include="..\Beutl.Extensions.MediaFoundation\Beutl.Extensions.MediaFoundation.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(AVFBuildIn)'=='True'">
    <ProjectReference
      Include="..\Beutl.Extensions.AVFoundation\Beutl.Extensions.AVFoundation.csproj" />
  </ItemGroup>

  <!-- ProjectReferences don't transitively copy native runtime assets (runtimes/<rid>/native),
       so mirror the Swift dylib from the referenced project's runtimes/ folder into this
       project's output via the AVF package's shared CopyBeutlAVFDylibsToConsumerOutput target.
       BeutlAVFOwnsSwiftBuild=false keeps the Swift build/packaging pipeline off in this import;
       the mirror is gated on AVFBuildIn so Linux/Windows publishes don't pick up the macOS-only
       dylibs. -->
  <PropertyGroup>
    <BeutlAVFOwnsSwiftBuild>false</BeutlAVFOwnsSwiftBuild>
    <CopyBeutlAVFDylibsToOutput Condition="'$(AVFBuildIn)'=='True'">true</CopyBeutlAVFDylibsToOutput>
  </PropertyGroup>
  <Import Project="..\Beutl.Extensions.AVFoundation\build\BeutlAVF.targets" />

  <Target Name="CopyBeutlAVFDylibForPublish"
          AfterTargets="Publish"
          Condition="'$(AVFBuildIn)'=='True' And '$(RuntimeIdentifier)' != '' And $(RuntimeIdentifier.StartsWith('osx'))">
    <PropertyGroup>
      <_BeutlAVFPublishSource>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)../Beutl.Extensions.AVFoundation/runtimes/$(RuntimeIdentifier)/native/libBeutlAVF.dylib'))</_BeutlAVFPublishSource>
    </PropertyGroup>
    <Copy SourceFiles="$(_BeutlAVFPublishSource)"
          DestinationFolder="$(PublishDir)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(_BeutlAVFPublishSource)')" />

    <!-- Sweep every libBeutlAVF.dylib that Build mirrored into runtimes/, then
         drop any folders left empty by the cleanup. CopyBeutlAVFDylibsToConsumerOutput
         intentionally seeds runtimes/<rid>/native for all RIDs so non-macOS
         pipelines can reuse them, but those copies are redundant once we have
         the dylib in the publish root, so we strip them here. -->
    <ItemGroup>
      <_BeutlAVFPublishStaleDylib Include="$(PublishDir)runtimes/**/libBeutlAVF.dylib" />
    </ItemGroup>
    <Delete Files="@(_BeutlAVFPublishStaleDylib)" />
    <ItemGroup>
      <_BeutlAVFPublishRuntimesRemain Include="$(PublishDir)runtimes/**" />
    </ItemGroup>
    <RemoveDir Directories="$(PublishDir)runtimes"
               Condition="Exists('$(PublishDir)runtimes') And '@(_BeutlAVFPublishRuntimesRemain)' == ''" />
  </Target>

  <ItemGroup>
    <None Update="ViewModels\Editors\VectorEditorViewModels.tt">
      <Generator>TextTemplatingFileGenerator</Generator>
      <LastGenOutput>VectorEditorViewModels.cs</LastGenOutput>
    </None>
  </ItemGroup>
  <ItemGroup>
    <Service Include="{508349b6-6b84-4df5-91f0-309beebad82d}" />
  </ItemGroup>
  <ItemGroup>
    <Compile Update="Pages\SettingsPages\PropertyEditorGroup.axaml.cs">
      <DependentUpon>%(Filename)</DependentUpon>
    </Compile>
    <Compile Update="ViewModels\Editors\VectorEditorViewModels.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>VectorEditorViewModels.tt</DependentUpon>
    </Compile>
    <Compile Update="Views\EditorHostFallback.axaml.cs">
      <DependentUpon>EditPageFallback.axaml</DependentUpon>
      <SubType>Code</SubType>
    </Compile>
    <Compile Update="Views\Dialogs\UpdateDialog.axaml.cs">
      <DependentUpon>UpdateDialog.axaml</DependentUpon>
      <SubType>Code</SubType>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Resources\osx-update.sh" />
    <EmbeddedResource Include="Resources\linux-update.sh" />
    <EmbeddedResource Include="Resources\win-update.ps1" />
  </ItemGroup>
  <ItemGroup>
    <AvaloniaResource Include="Resources\Fonts\**" />
  </ItemGroup>

  <Import Project="$(RootDirectory)\build\props\CoreLibraries.props" />
</Project>
