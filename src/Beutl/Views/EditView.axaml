<UserControl x:Class="Beutl.Views.EditView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dock="using:Dock.Avalonia.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Beutl.ViewModels"
             d:DesignHeight="720"
             d:DesignWidth="1280"
             x:CompileBindings="True"
             x:DataType="vm:EditViewModel"
             IsEnabled="{Binding IsEnabled.Value, Mode=OneWay}"
             mc:Ignorable="d">
    <dock:DockControl Name="DockControl"
                      Factory="{Binding DockHost.Factory}"
                      Layout="{Binding DockHost.Layout.Value}" />
</UserControl>
