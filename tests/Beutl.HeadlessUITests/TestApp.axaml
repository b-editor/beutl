<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:aconverters="using:Avalonia.Markup.Xaml.Converters"
             xmlns:asyncImageLoader="using:AsyncImageLoader"
             xmlns:sty="using:FluentAvalonia.Styling"
             xmlns:dockFluent="using:Dock.Avalonia.Themes.Fluent"
             xmlns:dockVm="using:Beutl.ViewModels.Dock"
             xmlns:views="using:Beutl.Views"
             x:Class="Beutl.HeadlessUITests.TestApp">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Beutl.Controls/Styling/Fonts.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <!--
        Production applies the default "beutl.dark.border" theme's overrides at runtime via
        ThemeService; the capture tests only flip RequestedThemeVariant, so mirror that theme here.
        Scoped to Dark (not merged flat) so the Light captures still show the classic light theme.
      -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <ResourceDictionary.MergedDictionaries>
            <ResourceInclude Source="avares://Beutl.Controls/Styling/Themes/BeutlDarkBorder.axaml" />
          </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <!-- ElementView (timeline rows) binds through this StaticResource; only App.axaml defines it. -->
      <aconverters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
    </ResourceDictionary>
  </Application.Resources>
  <!-- Without these, hosting EditView leaves the dockables as placeholders and the real tool views never inflate. -->
  <Application.DataTemplates>
    <DataTemplate DataType="dockVm:BeutlToolDockable">
      <views:ToolTabContent />
    </DataTemplate>
    <DataTemplate DataType="dockVm:PlayerToolDockable">
      <views:PlayerView DataContext="{Binding Player}" />
    </DataTemplate>
  </Application.DataTemplates>
  <!--
    Must mirror src/Beutl/App.axaml's style list exactly (same entries, same order): headless shell
    captures feed design review and must be faithful to production. Notably DockStyles.axaml
    re-templates ToolControl to put dock tab strips at the TOP of each panel (Dock's default is bottom).
  -->
  <Application.Styles>
    <sty:FluentAvaloniaTheme PreferUserAccentColor="True" TextVerticalAlignmentOverrideBehavior="Disabled" />
    <dockFluent:DockFluentTheme />
    <StyleInclude Source="avares://Beutl.Controls/Styles.axaml" />
    <StyleInclude Source="avares://AsyncImageLoader.Avalonia/AdvancedImage.axaml" />
    <StyleInclude Source="avares://Beutl.Editor.Components/Styles.axaml" />
    <StyleInclude Source="avares://Beutl/Views/Dock/DockStyles.axaml" />

    <Style Selector="asyncImageLoader|AdvancedImage">
      <Setter Property="Template">
        <ControlTemplate>
          <Grid>
            <!--  CurrentImage will be rendered with codebehind, just as it is done in the Image  -->
            <Border HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Classes.placeholder="{TemplateBinding IsLoading}"
                    IsVisible="{TemplateBinding IsLoading}" />
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="TextBox">
      <Setter Property="(TextBoxAttachment.EnterDownBehavior)" Value="Auto" />
    </Style>
  </Application.Styles>
</Application>
