+    private static void VerifyWrittenArtifacts(BaselineManifest manifest, string outputDirectory)
+    {
+        foreach ((string fileName, string expectedHash) in manifest.ArtifactSha256)
+        {
+            string path = Path.Combine(outputDirectory, fileName);
+            if (!File.Exists(path))
+                throw new FileNotFoundException("A generated artifact is missing.", path);
+            string actualHash = Sha256Hex(File.ReadAllBytes(path));
+            if (!string.Equals(expectedHash, actualHash, StringComparison.Ordinal))
+                throw new InvalidOperationException($"Hash mismatch after writing '{fileName}'.");
+
+            SceneManifest scene = manifest.Scenes.Single(item => item.Blob == fileName);
+            long expectedLength = checked((long)scene.BlobWidth * scene.BlobHeight * 8);
+            if (new FileInfo(path).Length != expectedLength)
+                throw new InvalidOperationException($"'{fileName}' is not tightly row-packed RGBA16F.");
+        }
+    }
