+    private static CapturedRender RenderCacheScene(string requestName, bool warm, bool drawContent)
+    {
+        using TargetBaselineProbe.Session probe = TargetBaselineProbe.Begin(requestName);
+        using RenderNode node = drawContent
+            ? new EllipseRenderNode(new Rect(31, 12, 118, 82), Brushes.Resource.CornflowerBlue, null)
+            : new EmptySourceNode();
+
+        if (warm)
+        {
+            node.Cache.ReportRenderCount(RenderNodeCache.Count);
+            RenderNodeCacheHelper.MakeCache(node, RenderCacheOptions.Default, 1f, 2f);
+            if (!node.Cache.IsCached)
+                throw new InvalidOperationException("The warm-cache evidence workload did not create a cache entry.");
+        }
+
+        int deviceWidth = Frame.Width;
+        int deviceHeight = Frame.Height;
+        using IDisposable allocationClass = TargetBaselineProbe.ClassifyAllocation("ExternalRoot");
+        using RenderTarget target = RenderTarget.Create(deviceWidth, deviceHeight)
+            ?? throw new InvalidOperationException($"{requestName}: external root allocation failed.");
+        var canvas = new ImmediateCanvas(target, 1f, 2f, Frame.ToSize(1));
+        canvas.Clear();
+        var processor = new RenderNodeProcessor(node, useRenderCache: warm, 1f, 2f);
+        RenderNodeOperation[] operations = processor.PullToRoot();
+        foreach (RenderNodeOperation operation in operations)
+        {
+            operation.Render(canvas);
+            operation.Dispose();
+        }
