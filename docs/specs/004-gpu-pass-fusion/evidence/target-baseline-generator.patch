+    private static string FixedUtf8(byte* value, uint maxLength)
+    {
+        int length = 0;
+        while (length < maxLength && value[length] != 0)
+            length++;
+        return Encoding.UTF8.GetString(new ReadOnlySpan<byte>(value, length));
+    }
+
+    private static string Hex(byte* properties, uint length)
+    {
+        return Convert.ToHexString(new ReadOnlySpan<byte>(properties, checked((int)length))).ToLowerInvariant();
+    }
+
+    private static string DecodeVulkanVersion(uint value)
+    {
+        uint major = value >> 22;
+        uint minor = (value >> 12) & 0x3ff;
+        uint patch = value & 0xfff;
+        return $"{major}.{minor}.{patch}";
+    }
