+    private static int Main(string[] args)
+    {
+        try
+        {
+            if (args.Length > 0 && args[0] == "--benchmark")
+                return RunBenchmarks(args[1..]);
+
+            string outputDirectory = ParseOutputDirectory(args);
+            string repositoryRoot = RequireEnvironment("BEUTL_BASELINE_REPO_ROOT");
+            VerifyBaselineCheckout(repositoryRoot);
+            PrepareEmptyOutputDirectory(outputDirectory);
+            SeedLogging();
+
+            GenerationBundle bundle = RenderThread.Dispatcher.Invoke(GenerateOnRenderThread);
+
+            foreach (GeneratedArtifact artifact in bundle.Artifacts)
+            {
+                File.WriteAllBytes(Path.Combine(outputDirectory, artifact.FileName), artifact.Bytes);
+            }
+
+            EvidenceTools tools = CreateEvidenceTools();
+            var artifactHashes = new SortedDictionary<string, string>(StringComparer.Ordinal);
+            foreach (GeneratedArtifact artifact in bundle.Artifacts)
+            {
+                artifactHashes[artifact.FileName] = Sha256Hex(artifact.Bytes);
+            }
+
+            var manifest = new BaselineManifest
+            {
+                SchemaVersion = 1,
+                BaselineCodeSha = BaselineSha,
+                BaselineCommitTimestamp = RunProcess("git", ["-C", repositoryRoot, "show", "-s", "--format=%cI", BaselineSha]).Trim(),
+                PrePatchRepositoryState = RequireEnvironment("BEUTL_BASELINE_PREPATCH_STATE"),
+                PatchedDiffSha256 = RequireEnvironment("BEUTL_BASELINE_PATCHED_DIFF_SHA256"),
+                GeneratorSeed = Seed,
+                RoiBaselineMode = "legacy-full-render-then-device-crop",
+                EvidenceTools = tools,
+                Fingerprint = bundle.Fingerprint,
+                PixelFormat = new PixelFormatManifest
+                {
+                    ColorType = "RGBA16F",
+                    AlphaType = "premultiplied",
+                    ColorSpace = "linear-sRGB",
+                    Endianness = "little",
+                    BytesPerPixel = 8,
+                    Packing = "row-packed-without-padding",
+                },
+                ArtifactSha256 = artifactHashes,
+                Scenes = bundle.Scenes,
+                AllocationFailures = bundle.AllocationFailures,
+                Benchmark = new BenchmarkManifest
+                {
+                    Command = "docs/specs/004-gpu-pass-fusion/evidence/generate-target-baseline.sh",
+                    Environment = "byte-identical evidence fingerprint required",
+                    RawResultReference = "docs/specs/004-gpu-pass-fusion/evidence/target-benchmark/manifest.json",
+                    Status = "starting-SHA BenchmarkDotNet baseline captured by the pinned-worktree driver",
+                },
+            };
+
+            ValidateManifest(manifest, bundle.Artifacts);
+            string manifestPath = Path.Combine(outputDirectory, "manifest.json");
+            File.WriteAllText(manifestPath, JsonSerializer.Serialize(manifest, JsonOptions) + "\n", new UTF8Encoding(false));
+            VerifyWrittenArtifacts(manifest, outputDirectory);
+
+            GraphicsContextFactory.Shutdown();
+            Console.WriteLine($"Generated {bundle.Artifacts.Count} immutable RGBA16F artifacts and manifest.json at {outputDirectory}");
+            return 0;
+        }
+        catch (Exception ex)
+        {
+            Console.Error.WriteLine(ex);
+            try
+            {
+                GraphicsContextFactory.Shutdown();
+            }
+            catch
+            {
+            }
+
+            return 1;
+        }
+    }
