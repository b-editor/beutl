diff --git a/src/Beutl.Engine/Graphics/Rendering/TargetBaselineProbe.cs b/src/Beutl.Engine/Graphics/Rendering/TargetBaselineProbe.cs
new file mode 100644
index 0000000000000000000000000000000000000000..d88c83aa384f814f4d89d0294a47df13736c049e
--- /dev/null
+++ b/src/Beutl.Engine/Graphics/Rendering/TargetBaselineProbe.cs
@@ -0,0 +1,247 @@
+namespace Beutl.Graphics.Rendering;
+
+// Evidence-only instrumentation. This file exists only in the patch applied to the pinned
+// target SHA; it is never compiled by the feature branch.
+internal static class TargetBaselineProbe
+{
+    [ThreadStatic]
+    private static State? s_state;
+
+    [ThreadStatic]
+    private static string? s_allocationClass;
+
+    internal static Session Begin(string requestName)
+    {
+        if (s_state != null)
+            throw new InvalidOperationException("A target-baseline probe session is already active on this thread.");
+
+        s_state = new State(requestName);
+        return new Session(s_state);
+    }
+
+    internal static string CurrentAllocationClass => s_allocationClass ?? "Unclassified";
+
+    internal static IDisposable ClassifyAllocation(string allocationClass)
+    {
+        string? previous = s_allocationClass;
+        s_allocationClass = allocationClass;
+        return new Scope(() => s_allocationClass = previous);
+    }
+
+    internal static void ArmAllocationFailure(string allocationClass)
+    {
+        State state = s_state ?? throw new InvalidOperationException("No target-baseline probe session is active.");
+        if (state.FailNextAllocationClass != null)
+            throw new InvalidOperationException("An allocation failure is already armed.");
+
+        state.FailNextAllocationClass = allocationClass;
+        state.Events.Add($"allocation-failure-armed:{allocationClass}");
+    }
+
+    internal static bool BeforeRenderTargetCreate(string allocationClass, int width, int height)
+    {
+        State? state = s_state;
+        if (state == null)
+            return false;
+
+        state.Increment("RenderTargetCreateAttempts");
+        state.Increment($"RenderTargetCreateAttempts.{allocationClass}");
+        state.Events.Add($"allocation-attempt:{allocationClass}:{width}x{height}");
+
+        if (state.FailNextAllocationClass == allocationClass)
+        {
+            state.FailNextAllocationClass = null;
+            state.AllocationFailureConsumed = true;
+            state.Events.Add($"allocation-injected-failure:{allocationClass}:{width}x{height}");
+            return true;
+        }
+
+        return false;
+    }
+
+    internal static void AfterRenderTargetCreate(string allocationClass, int width, int height, bool succeeded)
+    {
+        State? state = s_state;
+        if (state == null)
+            return;
+
+        string outcome = succeeded ? "Successes" : "Failures";
+        state.Increment($"RenderTargetCreate{outcome}");
+        state.Increment($"RenderTargetCreate{outcome}.{allocationClass}");
+        if (succeeded)
+        {
+            if (allocationClass.StartsWith("External", StringComparison.Ordinal))
+                state.Increment("ExternalRootResources");
+            else
+                state.Increment("LegacyIntermediateTargets");
+        }
+
+        state.Events.Add($"allocation-{(succeeded ? "success" : "failure")}:{allocationClass}:{width}x{height}");
+    }
+
+    internal static void RecordCanvasOpened()
+    {
+        s_state?.Increment("CanvasSessions");
+    }
+
+    internal static void RecordCanvasClosed()
+    {
+        s_state?.Increment("CanvasCloseFlushes");
+    }
+
+    internal static void RecordPrepareForSampling()
+    {
+        s_state?.Increment("PrepareForSamplingCalls");
+    }
+
+    internal static void RecordNodeProcess(RenderNode node)
+    {
+        State? state = s_state;
+        if (state == null)
+            return;
+
+        state.Increment("NodeProcessCalls");
+        state.Increment($"NodeProcessCalls.{node.GetType().Name}");
+    }
+
+    internal static void RecordOperationsEmitted(int count)
+    {
+        s_state?.Increment("OperationsEmitted", count);
+    }
+
+    internal static void RecordOperationExecution()
+    {
+        s_state?.Increment("OperationsExecuted");
+    }
+
+    internal static void RecordEffectMaterialization()
+    {
+        s_state?.Increment("EffectMaterializations");
+    }
+
+    internal static void RecordLegacyCustomEntry()
+    {
+        State? state = s_state;
+        if (state == null)
+            return;
+
+        state.Increment("LegacyCustomEntries");
+        state.Increment("OpaqueExternalExecutions");
+    }
+
+    internal static void RecordLegacyCustomTargetAllocation()
+    {
+        s_state?.Increment("LegacyCustomTargetAllocations");
+    }
+
+    internal static void RecordPreviewAllocationDrop()
+    {
+        s_state?.Increment("PreviewAllocationDrops");
+    }
+
+    internal static void RecordDeliveryAllocationThrow()
+    {
+        s_state?.Increment("DeliveryAllocationThrows");
+    }
+
+    internal static void RecordRenderCacheLookup(bool hit)
+    {
+        State? state = s_state;
+        if (state == null)
+            return;
+
+        state.Increment("RenderCacheLookups");
+        state.Increment(hit ? "RenderCacheHits" : "RenderCacheMisses");
+    }
+
+    internal static void RecordRenderCacheCapture()
+    {
+        s_state?.Increment("RenderCacheCaptures");
+    }
+
+    internal static void RecordRenderCacheRejection()
+    {
+        s_state?.Increment("RenderCacheRejections");
+    }
+
+    internal static void RecordThreeDBoundary()
+    {
+        s_state?.Increment("ThreeDBoundaries");
+    }
+
+    internal sealed class Session : IDisposable
+    {
+        private State? _state;
+
+        internal Session(State state)
+        {
+            _state = state;
+        }
+
+        internal TargetBaselineProbeSnapshot Snapshot()
+        {
+            State state = _state ?? throw new ObjectDisposedException(nameof(Session));
+            return state.CreateSnapshot();
+        }
+
+        public void Dispose()
+        {
+            State? state = Interlocked.Exchange(ref _state, null);
+            if (state == null)
+                return;
+
+            if (!ReferenceEquals(s_state, state))
+                throw new InvalidOperationException("The active target-baseline probe session changed unexpectedly.");
+            if (state.FailNextAllocationClass != null)
+                throw new InvalidOperationException(
+                    $"The armed allocation failure for '{state.FailNextAllocationClass}' was not consumed.");
+
+            s_state = null;
+            s_allocationClass = null;
+        }
+    }
+
+    internal sealed class State(string requestName)
+    {
+        private readonly Dictionary<string, long> _counters = new(StringComparer.Ordinal);
+
+        internal string RequestName { get; } = requestName;
+
+        internal List<string> Events { get; } = [];
+
+        internal string? FailNextAllocationClass { get; set; }
+
+        internal bool AllocationFailureConsumed { get; set; }
+
+        internal void Increment(string counter, long amount = 1)
+        {
+            _counters[counter] = _counters.GetValueOrDefault(counter) + amount;
+        }
+
+        internal TargetBaselineProbeSnapshot CreateSnapshot()
+        {
+            var counters = new SortedDictionary<string, long>(_counters, StringComparer.Ordinal);
+            return new TargetBaselineProbeSnapshot(
+                RequestName,
+                counters,
+                Events.ToArray(),
+                AllocationFailureConsumed);
+        }
+    }
+
+    private sealed class Scope(Action dispose) : IDisposable
+    {
+        private Action? _dispose = dispose;
+
+        public void Dispose()
+        {
+            Interlocked.Exchange(ref _dispose, null)?.Invoke();
+        }
+    }
+}
+
+internal sealed record TargetBaselineProbeSnapshot(
+    string RequestName,
+    IReadOnlyDictionary<string, long> Counters,
+    IReadOnlyList<string> Events,
+    bool AllocationFailureConsumed);
