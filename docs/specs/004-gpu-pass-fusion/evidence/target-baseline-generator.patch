+    private static void AddNonVacuityMetrics(
+        List<SceneManifest> scenes,
+        List<GeneratedArtifact> artifacts)
+    {
+        Dictionary<string, SceneManifest> sceneById = scenes.ToDictionary(scene => scene.Id, StringComparer.Ordinal);
+        Dictionary<string, GeneratedArtifact> artifactByFile = artifacts.ToDictionary(a => a.FileName, StringComparer.Ordinal);
+
+        foreach (SceneManifest scene in scenes.Where(scene => scene.Role == "parity"))
+        {
+            if (scene.ControlSceneId == null || !sceneById.TryGetValue(scene.ControlSceneId, out SceneManifest? control))
+                throw new InvalidOperationException($"Parity scene '{scene.Id}' has no control scene.");
+            if (scene.Blob == null || control.Blob == null)
+                throw new InvalidOperationException($"Parity/control blob missing for '{scene.Id}'.");
+
+            GeneratedArtifact actual = artifactByFile[scene.Blob];
+            GeneratedArtifact disabled = artifactByFile[control.Blob];
+            if (scene.BlobWidth != control.BlobWidth || scene.BlobHeight != control.BlobHeight)
+                throw new InvalidOperationException($"Non-vacuity dimensions differ for '{scene.Id}'.");
+
+            PixelDelta delta = Rgba16fWriter.CalculateDelta(
+                actual.Bytes,
+                disabled.Bytes,
+                scene.BlobWidth,
+                scene.BlobHeight,
+                scene.NonVacuityMode,
+                scene.NonVacuityRegion);
+            const double parityTolerance = 0.02;
+            double discriminator = Math.Max(delta.LinearRgbMae, delta.AlphaMae);
+            double margin = discriminator - parityTolerance;
+            if (margin <= 0.005)
+            {
+                throw new InvalidOperationException(
+                    $"Parity scene '{scene.Id}' is vacuous: RGB MAE={delta.LinearRgbMae:F6}, alpha MAE={delta.AlphaMae:F6}.");
+            }
+
+            scene.NonVacuity = new NonVacuityManifest
+            {
+                LinearRgbMae = delta.LinearRgbMae,
+                AlphaMae = delta.AlphaMae,
+                MaximumChannelError = delta.MaximumChannelError,
+                SampleCount = delta.SampleCount,
+                MetricMode = scene.NonVacuityMode,
+                MetricRegion = scene.NonVacuityRegion,
+                ParityTolerance = parityTolerance,
+                MarginAboveTolerance = margin,
+            };
+        }
+    }
