+    private static CapturedRender RenderManual(
+        string requestName,
+        Func<SceneFixture> fixtureFactory,
+        float outputScale,
+        float maxWorkingScale,
+        RequestedRegionManifest? requestedRegion = null)
+    {
+        using TargetBaselineProbe.Session probe = TargetBaselineProbe.Begin(requestName);
+        using SceneFixture fixture = fixtureFactory();
+        int deviceWidth = (int)MathF.Ceiling(Frame.Width * outputScale);
+        int deviceHeight = (int)MathF.Ceiling(Frame.Height * outputScale);
+        using IDisposable allocationClass = TargetBaselineProbe.ClassifyAllocation("ExternalRoot");
+        using RenderTarget target = RenderTarget.Create(deviceWidth, deviceHeight)
+            ?? throw new InvalidOperationException($"{requestName}: external root allocation failed.");
+        var canvas = new ImmediateCanvas(target, outputScale, maxWorkingScale, Frame.ToSize(1));
+        canvas.Clear();
+
+        var processor = new RenderNodeProcessor(fixture.Root, useRenderCache: fixture.UseRenderCache,
+            outputScale, maxWorkingScale);
+        RenderNodeOperation[] operations = processor.PullToRoot();
+        int consumed = 0;
+        try
+        {
+            foreach (RenderNodeOperation operation in operations)
+            {
+                operation.Render(canvas);
+                consumed++;
+                operation.Dispose();
+            }
+        }
+        catch
+        {
+            RenderNodeOperation.DisposeAll(operations.AsSpan(consumed));
+            throw;
+        }
+
+        canvas.Dispose();
+        using Bitmap full = target.Snapshot();
+        Bitmap? selected = SelectRequestedRegion(full, outputScale, requestedRegion);
+        TargetBaselineProbeSnapshot snapshot = probe.Snapshot();
+        return new CapturedRender(selected, snapshot, fixture.Query);
+    }
+
+    private static CapturedRender RenderDrawable(
+        string requestName,
+        Drawable.Resource resource,
+        float outputScale,
+        float maxWorkingScale)
+    {
+        using (resource)
+        using (var node = new DrawableRenderNode(resource))
+        {
+            using (var graphics = new GraphicsContext2D(node, Frame.ToSize(1), outputScale))
+            {
+                resource.GetOriginal().Render(graphics, resource);
+            }
+
+            return RenderExistingNode(requestName, node, outputScale, maxWorkingScale);
+        }
+    }
+
+    private static CapturedRender RenderExistingNode(
+        string requestName,
+        RenderNode root,
+        float outputScale,
+        float maxWorkingScale,
+        bool useCache = false)
+    {
+        using TargetBaselineProbe.Session probe = TargetBaselineProbe.Begin(requestName);
+        int deviceWidth = (int)MathF.Ceiling(Frame.Width * outputScale);
+        int deviceHeight = (int)MathF.Ceiling(Frame.Height * outputScale);
+        using IDisposable allocationClass = TargetBaselineProbe.ClassifyAllocation("ExternalRoot");
+        using RenderTarget target = RenderTarget.Create(deviceWidth, deviceHeight)
+            ?? throw new InvalidOperationException($"{requestName}: external root allocation failed.");
+        var canvas = new ImmediateCanvas(target, outputScale, maxWorkingScale, Frame.ToSize(1));
+        canvas.Clear();
+
+        var processor = new RenderNodeProcessor(root, useCache, outputScale, maxWorkingScale);
+        RenderNodeOperation[] operations = processor.PullToRoot();
+        try
+        {
+            foreach (RenderNodeOperation operation in operations)
+            {
+                operation.Render(canvas);
+                operation.Dispose();
+            }
+        }
+        catch
+        {
+            RenderNodeOperation.DisposeAll(operations);
+            throw;
+        }
+
+        canvas.Dispose();
+        Bitmap bitmap = target.Snapshot();
+        return new CapturedRender(bitmap, probe.Snapshot(), null);
+    }
