+internal static class Rgba16fWriter
+{
+    internal static byte[] Encode(Bitmap bitmap)
+    {
+        if (bitmap.ColorType != BitmapColorType.RgbaF16
+            || bitmap.AlphaType != BitmapAlphaType.Premul
+            || !bitmap.ColorSpace.Equals(BitmapColorSpace.LinearSrgb))
+        {
+            throw new InvalidOperationException("Baseline bitmap must be RgbaF16/Premul/LinearSrgb.");
+        }
+
+        byte[] bytes = new byte[checked(bitmap.Width * bitmap.Height * 8)];
+        int destination = 0;
+        for (int y = 0; y < bitmap.Height; y++)
+        {
+            ReadOnlySpan<ushort> row = bitmap.GetRow<ushort>(y);
+            if (row.Length != bitmap.Width * 4)
+                throw new InvalidOperationException("Unexpected RGBA16F row length.");
+            foreach (ushort component in row)
+            {
+                BinaryPrimitives.WriteUInt16LittleEndian(bytes.AsSpan(destination, 2), component);
+                destination += 2;
+            }
+        }
+
+        if (destination != bytes.Length)
+            throw new InvalidOperationException("RGBA16F writer did not fill the exact row-packed output.");
+        return bytes;
+    }
+
+    internal static PixelDelta CalculateDelta(
+        ReadOnlySpan<byte> left,
+        ReadOnlySpan<byte> right,
+        int width,
+        int height,
+        string mode,
+        RequestedRegionManifest? region)
+    {
+        if (left.Length != right.Length || left.Length != checked(width * height * 8))
+            throw new ArgumentException("RGBA16F buffers must have identical row-packed lengths.");
+
+        int minX = region?.X ?? 0;
+        int minY = region?.Y ?? 0;
+        int maxX = checked(minX + (region?.Width ?? width));
+        int maxY = checked(minY + (region?.Height ?? height));
+        if (minX < 0 || minY < 0 || maxX > width || maxY > height || minX >= maxX || minY >= maxY)
+            throw new ArgumentOutOfRangeException(nameof(region), "Metric region must be a non-empty subset of the image.");
+        if (mode is not ("full-frame" or "alpha-edge-band"))
+            throw new ArgumentOutOfRangeException(nameof(mode), $"Unknown non-vacuity metric mode '{mode}'.");
+
+        double rgb = 0;
+        double alpha = 0;
+        double maximum = 0;
+        int pixels = 0;
+        for (int y = minY; y < maxY; y++)
+        {
+            for (int x = minX; x < maxX; x++)
+            {
+                int pixelOffset = checked((y * width + x) * 8);
+                float leftAlpha = ReadHalf(left, pixelOffset + 6);
+                float rightAlpha = ReadHalf(right, pixelOffset + 6);
+                if (mode == "alpha-edge-band"
+                    && !IsCoverageEdge(leftAlpha)
+                    && !IsCoverageEdge(rightAlpha))
+                {
+                    continue;
+                }
+
+                pixels++;
+                for (int component = 0; component < 4; component++)
+                {
+                    int offset = pixelOffset + component * 2;
+                    double difference = Math.Abs(ReadHalf(left, offset) - ReadHalf(right, offset));
+                    maximum = Math.Max(maximum, difference);
+                    if (component == 3)
+                        alpha += difference;
+                    else
+                        rgb += difference;
+                }
+            }
+        }
+
+        if (pixels == 0)
+            throw new InvalidOperationException($"Non-vacuity metric mode '{mode}' selected no pixels.");
+
+        return new PixelDelta(rgb / (pixels * 3d), alpha / pixels, maximum, pixels);
+
+        static float ReadHalf(ReadOnlySpan<byte> bytes, int offset)
+        {
+            return (float)BitConverter.UInt16BitsToHalf(BinaryPrimitives.ReadUInt16LittleEndian(bytes.Slice(offset, 2)));
+        }
+
+        static bool IsCoverageEdge(float alpha)
+        {
+            return alpha > 0.01f && alpha < 0.75f;
+        }
+    }
