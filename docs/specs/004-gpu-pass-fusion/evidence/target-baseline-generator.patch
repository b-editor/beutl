+    private static Bitmap? SelectRequestedRegion(
+        Bitmap full,
+        float outputScale,
+        RequestedRegionManifest? requestedRegion)
+    {
+        if (requestedRegion == null)
+            return full.Clone();
+
+        int x = (int)MathF.Floor(requestedRegion.X * outputScale);
+        int y = (int)MathF.Floor(requestedRegion.Y * outputScale);
+        int right = (int)MathF.Ceiling((requestedRegion.X + requestedRegion.Width) * outputScale);
+        int bottom = (int)MathF.Ceiling((requestedRegion.Y + requestedRegion.Height) * outputScale);
+        int clippedX = Math.Clamp(x, 0, full.Width);
+        int clippedY = Math.Clamp(y, 0, full.Height);
+        int clippedRight = Math.Clamp(right, 0, full.Width);
+        int clippedBottom = Math.Clamp(bottom, 0, full.Height);
+        if (clippedRight <= clippedX || clippedBottom <= clippedY)
+            return null;
+
+        return full.ExtractSubset(new PixelRect(
+            clippedX,
+            clippedY,
+            clippedRight - clippedX,
+            clippedBottom - clippedY));
+    }
