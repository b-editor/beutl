+internal sealed class AnalyticCoverageNode(bool stroke, bool filled = false) : RenderNode
+{
+    public override RenderNodeOperation[] Process(RenderNodeContext context)
+    {
+        return
+        [
+            RenderNodeOperation.CreateLambda(
+                new Rect(10, 8, 172, 92),
+                canvas => Draw(canvas.Canvas),
+                point => new Rect(10, 8, 172, 92).Contains(point)),
+        ];
+    }
+
+    private void Draw(SKCanvas canvas)
+    {
+        using var paint = new SKPaint
+        {
+            IsAntialias = true,
+            Color = new SKColor(225, 85, 30, 205),
+            Style = filled ? SKPaintStyle.Fill : SKPaintStyle.Stroke,
+            StrokeWidth = stroke ? 1.25f : 0.75f,
+            StrokeCap = SKStrokeCap.Round,
+            StrokeJoin = SKStrokeJoin.Round,
+        };
+        if (filled)
+        {
+            canvas.DrawRoundRect(new SKRect(26.25f, 17.5f, 164.75f, 91.25f), 17, 17, paint);
+        }
+        else if (stroke)
+        {
+            using var path = new SKPath();
+            path.MoveTo(18.25f, 83.6f);
+            path.CubicTo(51.75f, 12.4f, 119.5f, 96.2f, 174.4f, 22.75f);
+            canvas.DrawPath(path, paint);
+        }
+        else
+        {
+            canvas.DrawLine(17.35f, 86.45f, 174.65f, 19.55f, paint);
+        }
+    }
