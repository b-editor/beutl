+internal sealed class TargetBaselineBenchmarkConfig : ManualConfig
+{
+    internal const int BenchmarkWarmupCount = 3;
+    internal const int BenchmarkIterationCount = 15;
+
+    public TargetBaselineBenchmarkConfig()
+    {
+        AddJob(Job.Default
+            .WithId("TargetBaselinePersistentGpu")
+            .WithStrategy(RunStrategy.Monitoring)
+            .WithLaunchCount(1)
+            .WithWarmupCount(BenchmarkWarmupCount)
+            .WithIterationCount(BenchmarkIterationCount)
+            .WithInvocationCount(1)
+            .WithUnrollFactor(1));
+        AddDiagnoser(MemoryDiagnoser.Default);
+        AddColumnProvider(DefaultColumnProviders.Instance);
+        AddLogger(ConsoleLogger.Default);
+        AddExporter(JsonExporter.Full);
+
+        string artifacts = Environment.GetEnvironmentVariable(TargetBaselineBenchmarks.ArtifactsEnvironmentVariable)
+            ?? throw new InvalidOperationException(
+                $"{TargetBaselineBenchmarks.ArtifactsEnvironmentVariable} is not set.");
+        ArtifactsPath = Path.GetFullPath(artifacts);
+    }
+}
