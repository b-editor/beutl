+    private static CapturedRender RenderCompositionRoots(string requestName, bool includeSecond)
+    {
+        using TargetBaselineProbe.Session probe = TargetBaselineProbe.Begin(requestName);
+        using Drawable.Resource first = BuildCompositionRect(left: true);
+        using Drawable.Resource? second = includeSecond ? BuildCompositionRect(left: false) : null;
+        ImmutableArray<EngineObject.Resource> objects = includeSecond
+            ? [first, second!]
+            : [first];
+        var frame = new CompositionFrame(objects, new TimeRange(TimeSpan.Zero, TimeSpan.FromTicks(1)), Frame);
+        using IDisposable allocationClass = TargetBaselineProbe.ClassifyAllocation("ExternalRoot");
+        using var renderer = new Renderer(Frame.Width, Frame.Height, 1f, 2f)
+        {
+            CacheOptions = RenderCacheOptions.Disabled,
+        };
+        renderer.Render(frame);
+        Bitmap bitmap = renderer.Snapshot();
+        return new CapturedRender(bitmap, probe.Snapshot(), null);
+    }
