+        return new SceneManifest
+        {
+            Id = id,
+            Category = "roi",
+            Role = "metadata",
+            Blob = null,
+            LogicalWidth = Frame.Width,
+            LogicalHeight = Frame.Height,
+            OutputScale = 1,
+            MaxWorkingScale = "2",
+            RequestedRegion = region,
+            Empty = true,
+            Parameters = Parameters(("roiSemantics", "legacy-full-render-then-device-crop")),
+            LegacyCounters = SortedCounters(first.Probe.Counters),
+            LegacyEvents = first.Probe.Events.ToArray(),
+        };
