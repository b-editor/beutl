+    private static void ValidateManifest(BaselineManifest manifest, IReadOnlyList<GeneratedArtifact> artifacts)
+    {
+        if (manifest.BaselineCodeSha != BaselineSha)
+            throw new InvalidOperationException("The manifest baseline SHA changed unexpectedly.");
+        if (manifest.Scenes.Count(scene => scene.Role == "parity") == 0)
+            throw new InvalidOperationException("No parity scenes were generated.");
+        if (!manifest.Scenes.Any(scene => scene.Id == "scene3d-with-2d-tail"
+                                         && scene.LegacyCounters.GetValueOrDefault("ThreeDBoundaries") >= 1))
+            throw new InvalidOperationException("The required 3D scene did not cross a real 3D boundary.");
+        if (!manifest.Scenes.Any(scene => scene.Id == "cache-warm-hit"
+                                         && scene.LegacyCounters.GetValueOrDefault("RenderCacheHits") >= 1
+                                         && scene.LegacyCounters.GetValueOrDefault("RenderCacheCaptures") >= 1))
+            throw new InvalidOperationException("The warm-cache scene did not capture and hit a cache.");
+        if (!manifest.Scenes.Any(scene => scene.Id == "bounds-hit-test-query" && scene.Query != null))
+            throw new InvalidOperationException("The query characterization is missing.");
+        if (!manifest.Scenes.Any(scene => scene.Id == "outside-roi" && scene.Empty && scene.Blob == null)
+            || !manifest.Scenes.Any(scene => scene.Id == "empty-roi" && scene.Empty && scene.Blob == null))
+            throw new InvalidOperationException("Empty/outside ROI characterizations are missing.");
+        if (manifest.AllocationFailures.Count != 2)
+            throw new InvalidOperationException("Both preview and delivery allocation failures are required.");
+        if (manifest.AllocationFailures.Single(x => x.Intent == "preview").Outcome != "dropped-output-without-throw")
+            throw new InvalidOperationException("Preview allocation behavior changed.");
+        if (manifest.AllocationFailures.Single(x => x.Intent == "delivery").ExceptionType != typeof(InvalidOperationException).FullName)
+            throw new InvalidOperationException("Delivery allocation behavior changed.");
+
+        var artifactNames = artifacts.Select(artifact => artifact.FileName).Order(StringComparer.Ordinal).ToArray();
+        var manifestNames = manifest.ArtifactSha256.Keys.Order(StringComparer.Ordinal).ToArray();
+        if (!artifactNames.SequenceEqual(manifestNames, StringComparer.Ordinal))
+            throw new InvalidOperationException("Manifest artifact set does not match generated blobs.");
+        foreach (SceneManifest scene in manifest.Scenes.Where(scene => scene.Blob != null))
+        {
+            if (!manifest.ArtifactSha256.ContainsKey(scene.Blob!))
+                throw new InvalidOperationException($"Scene '{scene.Id}' references an unhashed blob.");
+            if (scene.Role == "parity" && scene.NonVacuity == null)
+                throw new InvalidOperationException($"Scene '{scene.Id}' has no non-vacuity evidence.");
+        }
+    }
