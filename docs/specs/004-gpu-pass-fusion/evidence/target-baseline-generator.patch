+namespace Beutl.GpuPassTargetBaselineGenerator;
+
+[Config(typeof(TargetBaselineBenchmarkConfig))]
+public class TargetBaselineBenchmarks
+{
+    public const string ArtifactsEnvironmentVariable = "BEUTL_TARGET_BASELINE_BDN_ARTIFACTS";
+    public const string CountersEnvironmentVariable = "BEUTL_TARGET_BASELINE_COUNTERS";
+    public const int SetupWarmupFrameCount = 5;
+
+    private TargetBaselineBenchmarkSession? _session;
+    private Func<TargetBaselineBenchmarkFrame>? _renderFrame;
+    private TargetBaselineProbeSnapshot? _lastProbe;
+    private ulong _expectedChecksum;
+    private string _outputSha256 = "";
+
+    [Params("NoEffectControl", "ShaderOpacityShader", "ShaderOpacityShaderBarrier")]
+    public string CaseName { get; set; } = "";
+
+    [GlobalSetup]
+    public void Setup()
+    {
+        _session = RenderThread.Dispatcher.Invoke(() => new TargetBaselineBenchmarkSession(CaseName));
+        _renderFrame = _session.RenderFrame;
+
+        for (int index = 0; index < SetupWarmupFrameCount; index++)
+        {
+            TargetBaselineBenchmarkFrame frame = RenderThread.Dispatcher.Invoke(_renderFrame);
+            if (index == 0)
+            {
+                _expectedChecksum = frame.Checksum;
+            }
+            else if (frame.Checksum != _expectedChecksum)
+            {
+                throw new InvalidOperationException(
+                    $"Benchmark warm-up output changed for {CaseName}: {_expectedChecksum} -> {frame.Checksum}.");
+            }
+        }
+
+        _outputSha256 = RenderThread.Dispatcher.Invoke(_session.ComputeOutputSha256);
+    }
+
+    [Benchmark]
+    public ulong CompleteTargetFrame()
+    {
+        Func<TargetBaselineBenchmarkFrame> render = _renderFrame
+            ?? throw new InvalidOperationException("The benchmark session was not initialized.");
+        TargetBaselineBenchmarkFrame frame = RenderThread.Dispatcher.Invoke(render);
+        if (frame.Checksum != _expectedChecksum)
+        {
+            throw new InvalidOperationException(
+                $"Measured benchmark output changed for {CaseName}: {_expectedChecksum} -> {frame.Checksum}.");
+        }
+
+        _lastProbe = frame.Probe;
+        return frame.Checksum;
+    }
+
+    [GlobalCleanup]
+    public void Cleanup()
+    {
+        TargetBaselineBenchmarkSession? session = _session;
+        if (session == null)
+            return;
+
+        TargetBaselineProbeSnapshot probe = _lastProbe
+            ?? throw new InvalidOperationException($"Benchmark case {CaseName} completed without a measured request.");
+        TargetBaselineBenchmarkCounterRecord record = RenderThread.Dispatcher.Invoke(() =>
+        {
+            var result = new TargetBaselineBenchmarkCounterRecord
+            {
+                SchemaVersion = 1,
+                CaseName = CaseName,
+                Seed = Program.Seed,
+                Width = Program.Frame.Width,
+                Height = Program.Frame.Height,
+                SetupWarmupFrames = SetupWarmupFrameCount,
+                Lifetime = "persistent-root-external-target-canvas-processor-and-node-cache",
+                RenderCachePolicy = "persistent-node-cache-present; output-cache-selection-disabled",
+                RequestShape = "complete-target-frame-with-rgba16f-readback",
+                OutputSha256 = _outputSha256,
+                OutputChecksum = _expectedChecksum.ToString("x16"),
+                Fingerprint = session.Fingerprint,
+                LastRequestCounters = SortCounters(probe.Counters),
+                LastRequestEvents = probe.Events.ToArray(),
+            };
+            session.Dispose();
+            return result;
+        });
+
+        _session = null;
+        _renderFrame = null;
+
+        string directory = Environment.GetEnvironmentVariable(CountersEnvironmentVariable)
+            ?? throw new InvalidOperationException($"{CountersEnvironmentVariable} is not set.");
+        Directory.CreateDirectory(directory);
+        string path = Path.Combine(directory, CaseName + ".json");
+        using var stream = new FileStream(path, FileMode.CreateNew, FileAccess.Write, FileShare.None);
+        JsonSerializer.Serialize(stream, record, TargetBaselineBenchmarkCounterRecord.JsonOptions);
+        stream.WriteByte((byte)'\n');
+    }
+
+    private static SortedDictionary<string, long> SortCounters(IReadOnlyDictionary<string, long> counters)
+    {
+        var result = new SortedDictionary<string, long>(StringComparer.Ordinal);
+        foreach ((string name, long value) in counters)
+            result.Add(name, value);
+        return result;
+    }
+}
+
+internal sealed class TargetBaselineBenchmarkSession : IDisposable
+{
+    private readonly SceneFixture _fixture;
+    private readonly RenderTarget _target;
+    private readonly ImmediateCanvas _canvas;
+    private readonly RenderNodeProcessor _processor;
+    private readonly Bitmap _readback;
+
+    internal TargetBaselineBenchmarkSession(string caseName)
+    {
+        IGraphicsContext graphicsContext = GraphicsContextFactory.GetOrCreateShared()
+            ?? throw new InvalidOperationException("A real GPU context is required for the starting-SHA benchmark.");
+        Fingerprint = Program.CaptureFingerprint(graphicsContext);
+        _fixture = Program.CreateBenchmarkFixture(caseName);
+        using IDisposable allocationClass = TargetBaselineProbe.ClassifyAllocation("ExternalBenchmarkRoot");
+        _target = RenderTarget.Create(Program.Frame.Width, Program.Frame.Height)
+            ?? throw new InvalidOperationException("The persistent benchmark target could not be allocated.");
+        _canvas = new ImmediateCanvas(_target, 1f, 2f, Program.Frame.ToSize(1));
+        _processor = new RenderNodeProcessor(_fixture.Root, useRenderCache: false, 1f, 2f);
+        _readback = _target.CreateSnapshotBitmap();
+    }
+
+    internal EvidenceFingerprint Fingerprint { get; }
+
+    internal TargetBaselineBenchmarkFrame RenderFrame()
+    {
+        using TargetBaselineProbe.Session probe = TargetBaselineProbe.Begin("benchmark-complete-target-frame");
+        _canvas.Clear();
+        RenderNodeOperation[] operations = _processor.PullToRoot();
+        int consumed = 0;
+        try
+        {
+            foreach (RenderNodeOperation operation in operations)
+            {
+                operation.Render(_canvas);
+                consumed++;
+                operation.Dispose();
+            }
+        }
+        catch
+        {
+            RenderNodeOperation.DisposeAll(operations.AsSpan(consumed));
+            throw;
+        }
+
+        _target.SnapshotInto(_readback);
+        ulong checksum = CalculateSparseChecksum(_readback);
+        return new TargetBaselineBenchmarkFrame(checksum, probe.Snapshot());
+    }
+
+    internal string ComputeOutputSha256()
+    {
+        byte[] bytes = Rgba16fWriter.Encode(_readback);
+        return Convert.ToHexString(SHA256.HashData(bytes)).ToLowerInvariant();
+    }
+
+    public void Dispose()
+    {
+        _readback.Dispose();
+        _canvas.Dispose();
+        _target.Dispose();
+        _fixture.Dispose();
+    }
+
+    private static ulong CalculateSparseChecksum(Bitmap bitmap)
+    {
+        const ulong offset = 14695981039346656037;
+        const ulong prime = 1099511628211;
+        ulong result = offset;
+        for (int y = 0; y < bitmap.Height; y += 11)
+        {
+            ReadOnlySpan<ushort> row = bitmap.GetRow<ushort>(y);
+            for (int x = 0; x < bitmap.Width; x += 13)
+            {
+                int pixel = x * 4;
+                for (int channel = 0; channel < 4; channel++)
+                {
+                    result ^= row[pixel + channel];
+                    result *= prime;
+                }
+            }
+        }
+
+        return result;
+    }
+}
