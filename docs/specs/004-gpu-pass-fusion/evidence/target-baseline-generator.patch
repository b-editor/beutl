+    private static SceneManifest CaptureQueryScene()
+    {
+        static (QueryManifest Query, TargetBaselineProbeSnapshot Probe) Capture()
+        {
+            using TargetBaselineProbe.Session probe = TargetBaselineProbe.Begin("bounds-hit-test-query");
+            var pen = new Pen();
+            pen.Brush.CurrentValue = Brushes.White;
+            pen.Thickness.CurrentValue = 3;
+            using var penResource = (Pen.Resource)pen.ToResource(CompositionContext.Default);
+            using var node = new EllipseRenderNode(
+                new Rect(27.5f, 14.25f, 91.5f, 67.75f),
+                Brushes.Resource.CornflowerBlue,
+                penResource);
+            var processor = new RenderNodeProcessor(node, false, 1f, 2f);
+            RenderNodeOperation[] operations = processor.PullToRoot();
+            try
+            {
+                Rect bounds = operations.Aggregate(Rect.Empty, static (value, operation) => value.Union(operation.Bounds));
+                bool inside = operations.Any(operation => operation.HitTest(new Point(73, 48)));
+                bool outside = operations.Any(operation => operation.HitTest(new Point(2, 2)));
+                var query = new QueryManifest
+                {
+                    Bounds = RectString(bounds),
+                    InsidePoint = "73,48",
+                    InsideHit = inside,
+                    OutsidePoint = "2,2",
+                    OutsideHit = outside,
+                    LegacyQueryMayExecuteNodePulls = true,
+                };
+                return (query, probe.Snapshot());
+            }
+            finally
+            {
+                RenderNodeOperation.DisposeAll(operations);
+            }
+        }
+
+        var first = Capture();
+        var second = Capture();
+        if (JsonSerializer.Serialize(first.Query) != JsonSerializer.Serialize(second.Query)
+            || !CountersEqual(first.Probe.Counters, second.Probe.Counters))
+            throw new InvalidOperationException("Bounds/hit-test query characterization is unstable.");
+        if (!first.Query.InsideHit || first.Query.OutsideHit)
+            throw new InvalidOperationException("Bounds/hit-test query control points are not discriminating.");
+
+        return new SceneManifest
+        {
+            Id = "bounds-hit-test-query",
+            Category = "query",
+            Role = "metadata",
+            Blob = null,
+            LogicalWidth = Frame.Width,
+            LogicalHeight = Frame.Height,
+            OutputScale = 1,
+            MaxWorkingScale = "2",
+            Empty = false,
+            Parameters = Parameters(("queryExecution", "legacy-pull-may-execute-work")),
+            LegacyCounters = SortedCounters(first.Probe.Counters),
+            LegacyEvents = first.Probe.Events.ToArray(),
+            Query = first.Query,
+        };
+    }
