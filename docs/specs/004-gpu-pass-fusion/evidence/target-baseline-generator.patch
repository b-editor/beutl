+    private static AllocationFailureManifest CaptureAllocationFailure(
+        string intent,
+        float maxWorkingScale,
+        bool expectThrow)
+    {
+        FailureCapture first = RunAllocationFailure(intent, maxWorkingScale);
+        FailureCapture second = RunAllocationFailure(intent, maxWorkingScale);
+        if (first.Outcome != second.Outcome
+            || first.ExceptionType != second.ExceptionType
+            || first.ExceptionMessage != second.ExceptionMessage
+            || !CountersEqual(first.Probe.Counters, second.Probe.Counters))
+        {
+            throw new InvalidOperationException($"{intent} allocation-failure characterization is unstable.");
+        }
+
+        if (expectThrow != (first.ExceptionType != null))
+            throw new InvalidOperationException($"{intent} allocation-failure outcome did not match the target contract.");
+        if (!first.Probe.AllocationFailureConsumed)
+            throw new InvalidOperationException($"{intent} allocation-failure injection was not consumed.");
+        string requiredCounter = expectThrow ? "DeliveryAllocationThrows" : "PreviewAllocationDrops";
+        if (first.Probe.Counters.GetValueOrDefault(requiredCounter) != 1)
+            throw new InvalidOperationException($"{intent} did not increment {requiredCounter} exactly once.");
+
+        return new AllocationFailureManifest
+        {
+            Intent = intent,
+            InjectionPoint = "next EffectMaterialization RenderTarget.Create",
+            MaxWorkingScale = FloatString(maxWorkingScale),
+            Outcome = first.Outcome,
+            ExceptionType = first.ExceptionType,
+            ExceptionMessage = first.ExceptionMessage,
+            LegacyCounters = SortedCounters(first.Probe.Counters),
+            LegacyEvents = first.Probe.Events.ToArray(),
+        };
+    }
+
+    private static FailureCapture RunAllocationFailure(string intent, float maxWorkingScale)
+    {
+        using TargetBaselineProbe.Session probe = TargetBaselineProbe.Begin("allocation-failure-" + intent);
+        using var source = new AnalyticCoverageNode(stroke: false, filled: true);
+        var fixture = new SceneFixture();
+        var gamma = new Gamma();
+        gamma.Amount.CurrentValue = 165f;
+        fixture.Root = fixture.WrapEffect(source, gamma);
+        using (fixture)
+        using (IDisposable allocationClass = TargetBaselineProbe.ClassifyAllocation("ExternalRoot"))
+        using (RenderTarget target = RenderTarget.Create(Frame.Width, Frame.Height)
+               ?? throw new InvalidOperationException("Failure-characterization root allocation failed."))
+        using (var canvas = new ImmediateCanvas(target, 1f, maxWorkingScale, Frame.ToSize(1)))
+        {
+            canvas.Clear();
+            TargetBaselineProbe.ArmAllocationFailure("EffectMaterialization");
+            try
+            {
+                var processor = new RenderNodeProcessor(fixture.Root, false, 1f, maxWorkingScale);
+                RenderNodeOperation[] operations = processor.PullToRoot();
+                foreach (RenderNodeOperation operation in operations)
+                {
+                    operation.Render(canvas);
+                    operation.Dispose();
+                }
+
+                string outcome = operations.Length == 0 ? "dropped-output-without-throw" : "unexpected-output";
+                return new FailureCapture(outcome, null, null, probe.Snapshot());
+            }
+            catch (Exception ex)
+            {
+                return new FailureCapture("threw", ex.GetType().FullName, ex.Message, probe.Snapshot());
+            }
+        }
+    }
