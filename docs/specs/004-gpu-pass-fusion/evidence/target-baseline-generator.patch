+    private static GenerationBundle GenerateOnRenderThread()
+    {
+        IGraphicsContext graphicsContext = GraphicsContextFactory.GetOrCreateShared()
+            ?? throw new InvalidOperationException("A real GPU graphics context is required; fallback/null context is not valid evidence.");
+        if (!graphicsContext.Supports3DRendering)
+            throw new InvalidOperationException("The selected context does not support the required non-empty 3D evidence scene.");
+
+        EvidenceFingerprint fingerprint = CaptureFingerprint(graphicsContext);
+        List<VisualDefinition> definitions = CreateVisualDefinitions();
+        var artifacts = new List<GeneratedArtifact>(definitions.Count);
+        var scenes = new List<SceneManifest>(definitions.Count + 3);
+
+        foreach (VisualDefinition definition in definitions)
+        {
+            CapturedRender first = definition.Capture();
+            CapturedRender second = definition.Capture();
+            if (first.Bitmap == null || second.Bitmap == null)
+                throw new InvalidOperationException($"Visual scene '{definition.Id}' did not return a bitmap.");
+
+            using (first.Bitmap)
+            using (second.Bitmap)
+            {
+                byte[] firstBytes = Rgba16fWriter.Encode(first.Bitmap);
+                byte[] secondBytes = Rgba16fWriter.Encode(second.Bitmap);
+                if (!firstBytes.AsSpan().SequenceEqual(secondBytes))
+                    throw new InvalidOperationException($"Visual scene '{definition.Id}' is not byte-stable across two clean captures.");
+                if (!CountersEqual(first.Probe.Counters, second.Probe.Counters))
+                    throw new InvalidOperationException($"Visual scene '{definition.Id}' emitted unstable legacy counters.");
+
+                string fileName = definition.Id + ".rgba16f";
+                artifacts.Add(new GeneratedArtifact(fileName, firstBytes));
+                scenes.Add(new SceneManifest
+                {
+                    Id = definition.Id,
+                    Category = definition.Category,
+                    Role = definition.Role,
+                    ControlSceneId = definition.ControlSceneId,
+                    Blob = fileName,
+                    BlobWidth = first.Bitmap.Width,
+                    BlobHeight = first.Bitmap.Height,
+                    LogicalWidth = definition.LogicalSize.Width,
+                    LogicalHeight = definition.LogicalSize.Height,
+                    OutputScale = definition.OutputScale,
+                    MaxWorkingScale = FloatString(definition.MaxWorkingScale),
+                    RequestedRegion = definition.RequestedRegion,
+                    NonVacuityMode = definition.NonVacuityMode,
+                    NonVacuityRegion = definition.NonVacuityRegion,
+                    Empty = false,
+                    Parameters = definition.Parameters,
+                    LegacyCounters = SortedCounters(first.Probe.Counters),
+                    LegacyEvents = first.Probe.Events.ToArray(),
+                    Query = first.Query,
+                });
+            }
+        }
+
+        AddNonVacuityMetrics(scenes, artifacts);
+        AddMetadataOnlyScenes(scenes);
+
+        List<AllocationFailureManifest> allocationFailures = CaptureAllocationFailures();
+        return new GenerationBundle(fingerprint, artifacts, scenes, allocationFailures);
+    }
