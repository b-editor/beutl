+        CapturedRender second = RenderManual(id, () => BuildPrimaryChain(165, 0.62f, 72), 1f, 2f, region);
+        first.Bitmap?.Dispose();
+        second.Bitmap?.Dispose();
+        if (first.Bitmap != null || second.Bitmap != null)
+            throw new InvalidOperationException($"{id} unexpectedly produced a non-empty ROI bitmap.");
+        if (!CountersEqual(first.Probe.Counters, second.Probe.Counters))
+            throw new InvalidOperationException($"{id} legacy full-render counters are unstable.");
