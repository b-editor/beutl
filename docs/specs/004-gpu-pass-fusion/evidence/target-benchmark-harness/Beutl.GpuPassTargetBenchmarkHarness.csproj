<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Beutl.GpuPassTargetBenchmarkHarness</AssemblyName>
    <RootNamespace>Beutl.GpuPassTargetBenchmarkHarness</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
    <BaselineEngineProject Condition="'$(BaselineEngineProject)' == ''">$(BEUTL_BASELINE_ENGINE_PROJECT)</BaselineEngineProject>
  </PropertyGroup>

  <Target Name="RequireBaselineEngineProject" BeforeTargets="PrepareForBuild"
          Condition="'$(BaselineEngineProject)' == ''">
    <Error Text="BaselineEngineProject must identify the pinned starting-SHA Beutl.Engine.csproj." />
  </Target>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
    <ProjectReference Include="$(BaselineEngineProject)" />
  </ItemGroup>
</Project>
