{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/b-editor/beutl/specs/002-proxy-media/contracts/proxy-index.schema.json",
  "title": "Beutl Proxy Store Index",
  "description": "Definitions for <store-root>/index.json and per-source meta.json sidecars. index.json is the authoritative metadata for the on-disk proxy cache; meta.json mirrors entries for one source so the index can be rebuilt.",
  "type": "object",
  "required": ["version", "entries"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 2,
      "description": "Schema version. Unknown versions trigger a directory rescan and rewrite."
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/proxyEntry" }
    },
    "lastEvictionUtc": {
      "type": "string",
      "format": "date-time",
      "description": "Wall-clock time of the most recent LRU eviction sweep. Optional."
    }
  },
  "$defs": {
    "proxyEntry": {
      "type": "object",
      "required": ["source", "preset", "state", "proxyFileRelative", "proxyFileSizeBytes", "originalLogicalFrameSize", "proxyDecodedFrameSize", "generatedAtUtc", "lastUsedUtc"],
      "additionalProperties": false,
      "properties": {
        "source": { "$ref": "#/$defs/proxyFingerprint" },
        "preset": { "$ref": "#/$defs/proxyPreset" },
        "state": { "$ref": "#/$defs/proxyState" },
        "proxyFileRelative": {
          "type": "string",
          "description": "Forward-slash relative path under store root. Never rooted and never escapes the store root.",
          "pattern": "^(?!.*(^|/)\\.\\.(/|$))(?![A-Za-z]:)[^/\\\\][^\\\\]*$"
        },
        "proxyFileSizeBytes": {
          "type": "integer",
          "minimum": 0,
          "description": "0 is permitted only while state is Generating or Partial."
        },
        "originalLogicalFrameSize": {
          "$ref": "#/$defs/pixelSize",
          "description": "Original source frame size; the logical footprint a proxy must preserve."
        },
        "proxyDecodedFrameSize": {
          "$ref": "#/$defs/pixelSize",
          "description": "Decoded proxy frame size; used with originalLogicalFrameSize to compute supply density."
        },
        "generatedAtUtc": { "type": "string", "format": "date-time" },
        "lastUsedUtc":   { "type": "string", "format": "date-time" },
        "failureReason": {
          "type": ["string", "null"],
          "description": "Non-null iff state == Failed."
        }
      }
    },
    "proxySourceMetadata": {
      "type": "object",
      "required": ["version", "source", "entries"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "integer",
          "const": 2,
          "description": "Sidecar schema version. Unknown versions are ignored during index rebuild."
        },
        "source": { "$ref": "#/$defs/proxyFingerprint" },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/proxyEntry" },
          "description": "Proxy entries for this source. Each entry.source must equal the sidecar source."
        }
      }
    },
    "pixelSize": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      }
    },
    "proxyFingerprint": {
      "type": "object",
      "required": ["absolutePath", "fileSizeBytes", "mtimeUtc"],
      "additionalProperties": false,
      "properties": {
        "absolutePath": {
          "type": "string",
          "minLength": 1,
          "description": "Absolute, OS-normalized path to the source media file."
        },
        "fileSizeBytes": { "type": "integer", "minimum": 1 },
        "mtimeUtc": { "type": "string", "format": "date-time" }
      }
    },
    "proxyPreset": {
      "type": "string",
      "enum": ["Half", "Quarter", "Eighth"]
    },
    "proxyState": {
      "type": "string",
      "enum": ["None", "Generating", "Ready", "Stale", "Failed", "Partial"]
    }
  }
}
